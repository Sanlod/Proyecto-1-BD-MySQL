<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>
<?import java.net.URL?>

<AnchorPane prefHeight="700.0" prefWidth="1050.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.BuscarMascotasController">
   <stylesheets>
      <URL value="@style.css" />
   </stylesheets>
   <children>
      <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <AnchorPane fx:id="paginaBusqueda" style="-fx-background-color: #f4f7f6;">
               <children>
                  <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
                     <children>

                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
                           <children>
                              <VBox>
                                 <children>
                                    <Label text="Explorador de Mascotas" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
                                    <Label text="Consulta avanzada del registro centralizado" style="-fx-text-fill: #e8f8f5; -fx-font-size: 11px;" />
                                 </children>
                              </VBox>
                              <Region HBox.hgrow="ALWAYS" />
                              <Button fx:id="btnVolver" onAction="#switchVolver" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="↩ Volver al Menú" />
                           </children>
                        </HBox>

                        <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                           <children>
                              <VBox prefWidth="300.0" spacing="10.0" styleClass="card" style="-fx-padding: 15; -fx-background-color: white; -fx-background-radius: 10;">
                                 <children>
                                    <Label text="Filtros de Búsqueda" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 14px;" />
                                    <Separator />
                                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: white;">
                                       <content>
                                          <VBox spacing="8.0" style="-fx-background-color: white;">
                                             <children>
                                                <Label text="Estado Registro" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                                                <ComboBox fx:id="cmbEstado" maxWidth="Infinity" />

                                                <Label text="Raza" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                                                <ComboBox fx:id="cmbRaza" maxWidth="Infinity" />

                                                <Label text="Color" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                                                <ComboBox fx:id="cmbColor" maxWidth="Infinity" />

                                                <Label text="Rescatista / Asociación" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                                                <ComboBox fx:id="cmbRescatista" maxWidth="Infinity" />
                                                <ComboBox fx:id="cmbAsociacion" maxWidth="Infinity" />

                                                <Label text="Tipo de Mascota" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                                                <ComboBox fx:id="cmbTipo" maxWidth="Infinity" />

                                                <Separator style="-fx-padding: 5 0;" />
                                                <Label text="Ubicación" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #27ae60;" />
                                                <ComboBox fx:id="cmbProvincia" maxWidth="Infinity" promptText="Provincia" />
                                                <ComboBox fx:id="cmbCanton" maxWidth="Infinity" promptText="Cantón" />
                                                <ComboBox fx:id="cmbDistrito" maxWidth="Infinity" promptText="Distrito" />

                                                <Separator style="-fx-padding: 5 0;" />
                                                <TextField fx:id="txtNombre" promptText="Nombre de mascota..." />
                                                <TextField fx:id="txtNumChip" promptText="Número de Chip..." />

                                                <Label text="Rango de Fechas (Registro)" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                                                <DatePicker fx:id="dtDesde" maxWidth="Infinity" promptText="Desde" />
                                                <DatePicker fx:id="dtHasta" maxWidth="Infinity" promptText="Hasta" />
                                             </children>
                                          </VBox>
                                       </content>
                                    </ScrollPane>
                                    <VBox spacing="8" style="-fx-padding: 10 0 0 0;">
                                       <children>
                                          <Button fx:id="btnBuscar" maxWidth="Infinity" onAction="#onBuscar" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="🔍 Realizar Búsqueda" />
                                          <Button fx:id="btnLimpiar" maxWidth="Infinity" onAction="#onLimpiar" styleClass="button-secondary" style="-fx-background-radius: 8;" text="Limpiar Filtros" />
                                       </children>
                                    </VBox>
                                 </children>
                              </VBox>

                              <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <TableView fx:id="tblDatos" VBox.vgrow="ALWAYS" style="-fx-selection-bar: #e8f8f5;">
                                       <columns>
                                          <TableColumn fx:id="colNombre" text="Nombre" prefWidth="100" />
                                          <TableColumn fx:id="colTipo" text="Tipo" prefWidth="80" />
                                          <TableColumn fx:id="colRaza" text="Raza" prefWidth="100" />
                                          <TableColumn fx:id="colColor" text="Color" prefWidth="80" />
                                          <TableColumn fx:id="colEstado" text="Estado" prefWidth="100" />
                                          <TableColumn fx:id="colUbicacion" text="Ubicación" prefWidth="120" />
                                          <TableColumn fx:id="colFecha" text="Registro" prefWidth="100" />
                                       </columns>
                                       <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                    </TableView>

                                    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="card" style="-fx-padding: 12; -fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #27ae60; -fx-border-width: 2 0 0 0;">
                                       <children>
                                          <VBox alignment="CENTER" style="-fx-border-color: #ddd; -fx-border-radius: 5; -fx-padding: 5; -fx-background-color: #f8f9fa;">
                                             <ImageView fx:id="imvMascota" fitHeight="70.0" fitWidth="100.0" preserveRatio="true" />
                                          </VBox>
                                          <VBox spacing="5">
                                             <children>
                                                <Label fx:id="lblTotal" text="Total: 0 resultados" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" />
                                                <Label text="Seleccione una fila para ver previsualización" style="-fx-font-size: 10px; -fx-text-fill: #95a5a6; -fx-font-style: italic;" />
                                             </children>
                                          </VBox>
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Button fx:id="btnVerDetalle" onAction="#onVerDetalle" style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 20;" text="📄 Ver Detalle Completo" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>

            <AnchorPane fx:id="paginaDetalle" visible="false" style="-fx-background-color: #f4f7f6;">
               <children>
                  <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
                     <children>
                        <HBox>
                           <children>
                              <Button fx:id="btnVolverBusqueda" onAction="#onVolverBusqueda" styleClass="button-secondary" style="-fx-background-radius: 8;" text="⬅ Volver a los resultados" />
                              <Region HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>

                        <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                           <children>
                              <VBox spacing="15.0" prefWidth="420.0" styleClass="card" style="-fx-padding: 20; -fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #16a085; -fx-border-width: 0 0 0 5;">
                                 <children>
                                    <Label text="Ficha Técnica de la Mascota" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #16a085;" />
                                    <Separator />
                                    <GridPane vgap="8" hgap="10">
                                       <columnConstraints>
                                          <ColumnConstraints prefWidth="130" />
                                          <ColumnConstraints hgrow="ALWAYS" />
                                       </columnConstraints>
                                       <children>
                                          <Label text="Nombre:" GridPane.rowIndex="0" style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold;" />
                                          <Label fx:id="lblDetalleNombre" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2c3e50;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                          <Label text="Tipo / Raza:" GridPane.rowIndex="1" style="-fx-text-fill: #7f8c8d;" />
                                          <HBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                             <children>
                                                <Label fx:id="lblDetalleTipo" style="-fx-font-weight: bold;" />
                                                <Label text="-" />
                                                <Label fx:id="lblDetalleRaza" style="-fx-font-weight: bold;" />
                                             </children>
                                          </HBox>

                                          <Label text="Color:" GridPane.rowIndex="2" style="-fx-text-fill: #7f8c8d;" />
                                          <Label fx:id="lblDetalleColor" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                          <Label text="Chip ID:" GridPane.rowIndex="3" style="-fx-text-fill: #7f8c8d;" />
                                          <Label fx:id="lblDetalleChip" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                          <Label text="Estado Registro:" GridPane.rowIndex="4" style="-fx-text-fill: #7f8c8d;" />
                                          <Label fx:id="lblDetalleEstado" style="-fx-text-fill: #d35400; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                          <Label text="Nivel de Energía:" GridPane.rowIndex="5" style="-fx-text-fill: #7f8c8d;" />
                                          <Label fx:id="lblDetalleEnergia" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                       </children>
                                    </GridPane>

                                    <Separator />
                                    <VBox spacing="5" style="-fx-background-color: #e8f8f5; -fx-padding: 10; -fx-background-radius: 5;">
                                       <children>
                                          <Label text="Descripción Abandono:" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #16a085;" />
                                          <Label fx:id="lblDetalleDescAbandono" wrapText="true" style="-fx-text-fill: #2c3e50;" />
                                       </children>
                                    </VBox>
                                    <VBox spacing="5" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 5;">
                                       <children>
                                          <Label text="Notas Adicionales:" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                                          <Label fx:id="lblDetalleNotas" wrapText="true" style="-fx-text-fill: #555;" />
                                       </children>
                                    </VBox>
                                 </children>
                              </VBox>

                              <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <HBox spacing="15.0" prefHeight="260.0">
                                       <children>
                                          <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS" styleClass="card" style="-fx-background-color: white; -fx-background-radius: 10;">
                                             <children>
                                                <Label text="Foto al Ingreso" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                                                <ImageView fx:id="imvDetalleAntes" fitHeight="190.0" fitWidth="230.0" preserveRatio="true" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);" />
                                             </children>
                                          </VBox>
                                          <VBox alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS" styleClass="card" style="-fx-background-color: white; -fx-background-radius: 10;">
                                             <children>
                                                <Label text="Foto Actual" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                                                <ImageView fx:id="imvDetalleDespues" fitHeight="190.0" fitWidth="230.0" preserveRatio="true" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);" />
                                             </children>
                                          </VBox>
                                       </children>
                                    </HBox>

                                    <VBox spacing="10.0" styleClass="card" style="-fx-padding: 20; -fx-background-color: white; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                                       <children>
                                          <Label text="🌐 Información de Ubicación y Contacto" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                          <Separator />
                                          <GridPane vgap="10" hgap="20">
                                             <children>
                                                <Label text="Ubicación Registrada:" GridPane.rowIndex="0" style="-fx-text-fill: #7f8c8d;" />
                                                <Label fx:id="lblDetalleUbicacion" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                                <Label text="Teléfono Contacto:" GridPane.rowIndex="1" style="-fx-text-fill: #7f8c8d;" />
                                                <Label fx:id="lblDetalleTelefono" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                                <Label text="E-mail:" GridPane.rowIndex="2" style="-fx-text-fill: #7f8c8d;" />
                                                <Label fx:id="lblDetalleEmail" style="-fx-text-fill: #2980b9; -fx-underline: true;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                                <Label text="Rescatista Asociado:" GridPane.rowIndex="3" style="-fx-text-fill: #7f8c8d;" />
                                                <Label fx:id="lblDetalleRescatista" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                                <Label text="Dificultad Entrenamiento:" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-text-fill: #7f8c8d;" />
                                                <Label fx:id="lblDetalleDificultad" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                                             </children>
                                          </GridPane>

                                          <Label fx:id="lblDetalleSeveridad" visible="false" managed="false" />
                                          <Label fx:id="lblDetalleTamanio" visible="false" managed="false" />
                                          <Label fx:id="lblDetalleEspacio" visible="false" managed="false" />
                                          <Label fx:id="lblDetalleAsociacion" visible="false" managed="false" />
                                          <Label fx:id="lblDetalleVeterinario" visible="false" managed="false" />
                                          <Label fx:id="lblDetalleCasaCuna" visible="false" managed="false" />
                                          <Label fx:id="lblDetalleFechaPerdida" visible="false" managed="false" />
                                          <Label fx:id="lblDetalleFechaHallazgo" visible="false" managed="false" />
                                       </children>
                                    </VBox>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>

         </children>
      </StackPane>
   </children>
</AnchorPane>
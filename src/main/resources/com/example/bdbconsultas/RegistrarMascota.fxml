<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.RegistrarMascotasController">
   <children>
      <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <AnchorPane fx:id="pagina1" prefHeight="700.0" prefWidth="1000.0">
               <children>

                  <HBox alignment="CENTER_LEFT" layoutX="15.0" layoutY="15.0" prefHeight="70.0" prefWidth="970.0" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
                     <children>
                        <VBox>
                           <children>
                              <Label text="Formulario de Registro - Paso 1" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
                              <Label text="Manejo de reportes de mascotas" style="-fx-text-fill: #e8f8f5; -fx-font-size: 11px;" />
                           </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnVolver" onAction="#switchVolver" prefWidth="90.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="↩ Volver" />
                     </children>
                  </HBox>

                  <Pane layoutX="15.0" layoutY="100.0" prefHeight="510.0" prefWidth="970.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                     <children>

                        <Label layoutX="25.0" layoutY="20.0" text="Identificación" style="-fx-font-weight: bold; -fx-text-fill: #16a085; -fx-font-size: 14px;" />
                        <VBox layoutX="25.0" layoutY="50.0" spacing="10.0">
                           <children>
                              <VBox><Label text="Nombre" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><TextField fx:id="txtIdNombre1" prefWidth="180.0" /></VBox>
                              <VBox><Label text="Tipo" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbIdTipo1" prefWidth="180.0" /></VBox>
                              <VBox><Label text="Color" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbIdColor1" prefWidth="180.0" /></VBox>
                              <VBox><Label text="Raza" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbIdRaza1" prefWidth="180.0" /></VBox>
                              <VBox><Label text="Chip ID" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><TextField fx:id="txtChip1" prefWidth="180.0" /></VBox>
                           </children>
                        </VBox>

                        <Label layoutX="240.0" layoutY="20.0" text="Ubicación y Salud" style="-fx-font-weight: bold; -fx-text-fill: #16a085; -fx-font-size: 14px;" />
                        <VBox layoutX="240.0" layoutY="50.0" spacing="10.0">
                           <children>
                              <VBox><Label text="Fecha Nacimiento" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><DatePicker fx:id="birthDatePicker" prefWidth="180.0" /></VBox>
                              <VBox><Label text="Provincia" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbIdProvincia1" prefWidth="180.0" /></VBox>
                              <VBox><Label text="Cantón" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbIdCanton1" prefWidth="180.0" /></VBox>
                              <VBox><Label text="Distrito" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbIdDistrito1" prefWidth="180.0" /></VBox>
                              <VBox><Label text="Severidad" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbIdSeveridad1" prefWidth="180.0" /></VBox>
                           </children>
                        </VBox>

                        <Label layoutX="455.0" layoutY="20.0" text="Recompensa y Energía" style="-fx-font-weight: bold; -fx-text-fill: #16a085; -fx-font-size: 14px;" />
                        <VBox layoutX="455.0" layoutY="50.0" spacing="10.0">
                           <children>
                              <VBox><Label text="Estado Actual" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbIdEstado1" prefWidth="180.0" /></VBox>
                              <VBox><Label text="Nivel de Energía" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbIdNivEnergia1" prefWidth="180.0" /></VBox>
                              <VBox><Label text="Monto" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><TextField fx:id="txtMonto1" prefWidth="180.0" /></VBox>
                              <VBox><Label text="Moneda" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbIdMoneda1" prefWidth="180.0" /></VBox>
                           </children>
                        </VBox>

                        <VBox layoutX="670.0" layoutY="20.0" spacing="8.0">
                           <children>
                              <VBox><Label text="Descripción" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" /><TextArea fx:id="txtDescripcion1" prefHeight="90.0" prefWidth="275.0" wrapText="true" /></VBox>
                              <VBox><Label text="Notas Abandono" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" /><TextArea fx:id="txtNotasAbandono" prefHeight="90.0" prefWidth="275.0" wrapText="true" /></VBox>

                              <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #f9f9f9; -fx-padding: 10; -fx-background-radius: 8;">
                                 <children>
                                    <VBox alignment="CENTER" spacing="5">
                                       <children>
                                          <Button fx:id="btnFotoAntes1" onAction="#onExaminarAntes" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 10px;" text="📸 Antes" />
                                          <ImageView fx:id="imvFotoAntes" fitHeight="110.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(one-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);" />
                                       </children>
                                    </VBox>
                                    <VBox alignment="CENTER" spacing="5">
                                       <children>
                                          <Button fx:id="btnFotoDesp1" onAction="#onExaminarDespues" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-size: 10px;" text="📸 Después" />
                                          <ImageView fx:id="imvFotoDespues" fitHeight="110.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(one-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </Pane>

                  <Button layoutX="805.0" layoutY="630.0" onAction="#onIrPagina2" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="Siguiente Paso (II) →" />
               </children>
            </AnchorPane>

            <AnchorPane fx:id="pagina2" prefHeight="700.0" prefWidth="1000.0" visible="false">
               <children>

                  <HBox alignment="CENTER_LEFT" layoutX="15.0" layoutY="15.0" prefHeight="70.0" prefWidth="970.0" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
                     <children>
                        <VBox>
                           <children>
                              <Label text="Formulario de Registro - Paso 2" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
                              <Label text="Detalles adicionales y responsables" style="-fx-text-fill: #e8f8f5; -fx-font-size: 11px;" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <Pane layoutX="15.0" layoutY="100.0" prefHeight="500.0" prefWidth="970.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                     <children>
                        <Label layoutX="40.0" layoutY="30.0" text="Detalles Técnicos" style="-fx-font-weight: bold; -fx-text-fill: #16a085; -fx-font-size: 14px;" />
                        <VBox layoutX="40.0" layoutY="60.0" spacing="15.0">
                           <children>
                              <VBox><Label text="Tamaño" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbTamanio" prefWidth="220.0" /></VBox>
                              <VBox><Label text="Dificultad de entrenamiento" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbDificultadEntrenamiento" prefWidth="220.0" /></VBox>
                              <CheckBox fx:id="chkRequiereEspacio" style="-fx-font-weight: bold;" text="Requiere espacio amplio" />
                              <VBox><Label text="Fecha de pérdida" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><DatePicker fx:id="dpFechaperdida" prefWidth="220.0" /></VBox>
                           </children>
                        </VBox>

                        <Label layoutX="320.0" layoutY="30.0" text="Contacto y Responsables" style="-fx-font-weight: bold; -fx-text-fill: #16a085; -fx-font-size: 14px;" />
                        <VBox layoutX="320.0" layoutY="60.0" spacing="15.0">
                           <children>
                              <VBox><Label text="Teléfono" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><TextField fx:id="txtTelefono" prefWidth="220.0" /></VBox>
                              <VBox><Label text="Correo" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><TextField fx:id="txtCorreo" prefWidth="220.0" /></VBox>

                              <Label text="Asignaciones" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                              <VBox><Label text="Veterinario (Nombre)" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><TextField fx:id="txtVeterinario" prefWidth="220.0" promptText="Solo letras..." /></VBox>
                              <VBox><Label text="Rescatista" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbRescatista" prefWidth="220.0" /></VBox>
                              <VBox><Label text="Asociación" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" /><ComboBox fx:id="cmbAsociacion" prefWidth="220.0" /></VBox>
                           </children>
                        </VBox>

                        <ImageView fitHeight="200.0" fitWidth="200.0" layoutX="680.0" layoutY="100.0" opacity="0.1" pickOnBounds="true" preserveRatio="true">
                           <image>
                           </image>
                        </ImageView>
                     </children>
                  </Pane>

                  <Button layoutX="15.0" layoutY="630.0" onAction="#onIrPagina1" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20;" text="← Página I" />
                  <Button fx:id="btnRegistrar" layoutX="755.0" layoutY="620.0" onAction="#onRegistrar" prefHeight="50.0" prefWidth="230.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4); -fx-cursor: hand;" text="✅ REGISTRAR MASCOTA" />
               </children>
            </AnchorPane>

         </children>
      </StackPane>
   </children>
</AnchorPane>
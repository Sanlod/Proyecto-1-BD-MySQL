<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="680.0" prefWidth="926.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.SinAdoptarController">
   <children>
      <TableView fx:id="mascotasTable" layoutX="45.0" layoutY="168.0" prefHeight="422.0" prefWidth="854.0">
        <columns>
          <TableColumn prefWidth="75.0" text="C1" />
          <TableColumn prefWidth="75.0" text="C2" />
        </columns>
      </TableView>
      <Spinner fx:id="meses" layoutX="45.0" layoutY="37.0" />
      <Text layoutX="45.0" layoutY="27.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Meses sin adoptar" />
      <ComboBox fx:id="tipo" layoutX="231.0" layoutY="37.0" onAction="#actualizarRazas" prefWidth="150.0" />
      <Text layoutX="231.0" layoutY="27.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Tipo de mascota" />
      <ComboBox fx:id="raza" layoutX="403.0" layoutY="37.0" prefWidth="150.0" />
      <Text layoutX="403.0" layoutY="27.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Raza" />
      <ComboBox fx:id="color" layoutX="578.0" layoutY="37.0" prefWidth="150.0" />
      <Text layoutX="578.0" layoutY="27.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Color" />
      <Text layoutX="127.0" layoutY="153.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Mascotas:" />
      <Label fx:id="total" layoutX="181.0" layoutY="140.0" text="Label" />
      <Button layoutX="45.0" layoutY="136.0" mnemonicParsing="false" onAction="#buscar" text="Buscar" />
      <Button layoutX="32.0" layoutY="628.0" mnemonicParsing="false" onAction="#switchVolver" text="Volver" />
   </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.BitacoraController">
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
         <children>

            <HBox alignment="CENTER_LEFT" prefHeight="65.0" style="-fx-background-color: linear-gradient(to right, #34495e, #2c3e50); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
               <children>
                  <VBox>
                     <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="Bitácora de Eventos (Logs)" />
                        <Label style="-fx-text-fill: #bdc3c7; -fx-font-size: 11px;" text="Seguimiento de cambios y operaciones en la base de datos" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#switchVolver" prefWidth="90.0" style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="↩ Volver" />
               </children>
            </HBox>

            <HBox alignment="BOTTOM_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);">
               <children>
                  <VBox spacing="2">
                     <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Usuario Responsable" />
                     <ComboBox fx:id="usuario" prefWidth="180.0" promptText="Seleccionar usuario..." />
                  </VBox>
                  <VBox spacing="2">
                     <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Tabla Afectada" />
                     <ComboBox fx:id="tablacbx" prefWidth="180.0" promptText="Todas las tablas" />
                  </VBox>
                  <VBox spacing="2">
                     <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Fecha de Registro" />
                     <DatePicker fx:id="fecha" prefWidth="180.0" />
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#buscar" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🔍 Consultar" />
               </children>
            </HBox>

            <VBox spacing="8.0" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Historial de Transacciones" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label style="-fx-text-fill: #16a085; -fx-font-size: 11px; -fx-font-weight: bold;" text="Visualización en Tiempo Real" />
                     </children>
                  </HBox>

                  <TableView fx:id="tabla" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn prefWidth="120.0" text="FECHA / HORA" />
                        <TableColumn prefWidth="100.0" text="USUARIO" />
                        <TableColumn prefWidth="100.0" text="OPERACIÓN" />
                        <TableColumn prefWidth="120.0" text="TABLA" />
                        <TableColumn prefWidth="300.0" text="DETALLE DEL CAMBIO" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>

         </children>
      </VBox>
   </children>
</AnchorPane>
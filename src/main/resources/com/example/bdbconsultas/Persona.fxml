<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="980.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.PersonaController">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="10.0">
            <children>

                <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 10; -fx-padding: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
                    <children>
                        <VBox>
                            <children>
                                <Label text="Gestión de Usuarios y Roles" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
                                <Label text="Administración de personas y estatus de seguridad" style="-fx-text-fill: #e8f8f5; -fx-font-size: 11px;" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnVolver" onAction="#switchVolver" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="↩ Volver" />
                    </children>
                </HBox>

                <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox prefWidth="200.0" spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                            <children>
                                <Label text="Acciones de Edición" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                <Button fx:id="btnEditar" maxWidth="Infinity" onAction="#onEditar" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="📝 Editar" />
                                <Button fx:id="btnGuardar" maxWidth="Infinity" onAction="#onGuardar" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="💾 Guardar" />
                                <Button fx:id="btnCancelar" maxWidth="Infinity" onAction="#onCancelar" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold;" text="✖ Cancelar" />

                                <Separator />
                                <Label text="Cambio de Roles" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                <Button fx:id="btnReportarListaNegra" maxWidth="Infinity" onAction="#onReportarListaNegra" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="⚠️ Lista Negra" />
                                <Button fx:id="btnMakeAdmin" maxWidth="Infinity" onAction="#onMakeAdmin" style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold;" text="🔑 Admin" />
                                <Button fx:id="btnMakeRescuer" maxWidth="Infinity" onAction="#onMakeRescuer" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold;" text="🐾 Rescatista" />
                            </children>
                        </VBox>

                        <TableView fx:id="tblDatos" style="-fx-selection-bar: #e8f8f5;" HBox.hgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" maxWidth="80.0" prefWidth="70.0" text="ID" />
                                <TableColumn fx:id="colNombreCompleto" prefWidth="500.0" text="Nombre Completo del Usuario" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </HBox>

                <VBox spacing="8.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #16a085; -fx-border-width: 2 0 0 0; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <children>
                        <GridPane hgap="20.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="300.0" />
                            </columnConstraints>
                            <children>
                                <VBox spacing="2">
                                    <Label text="Identificación (ID):" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                                    <TextField fx:id="txtId" editable="false" style="-fx-background-color: #f1f2f6;" />
                                </VBox>
                                <VBox spacing="2" GridPane.rowIndex="1">
                                    <Label text="Primer Nombre:" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                                    <TextField fx:id="txtPrimerNombre" />
                                </VBox>
                                <VBox spacing="2" GridPane.rowIndex="2">
                                    <Label text="Primer Apellido:" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                                    <TextField fx:id="txtPrimerApellido" />
                                </VBox>

                                <VBox spacing="2" GridPane.columnIndex="1">
                                    <Label text="Calificación Actual:" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                                    <TextField fx:id="txtCalificacion" editable="false" style="-fx-background-color: #f1f2f6;" />
                                </VBox>
                                <VBox spacing="2" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <Label text="Segundo Nombre:" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                                    <TextField fx:id="txtSegundoNombre" />
                                </VBox>
                                <VBox spacing="2" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <Label text="Segundo Apellido:" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                                    <TextField fx:id="txtSegundoApellido" />
                                </VBox>

                                <VBox spacing="2" GridPane.columnIndex="2" GridPane.rowSpan="2">
                                    <Label text="Notas / Observaciones:" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                                    <TextArea fx:id="txtNotas" prefHeight="75.0" wrapText="true" />
                                </VBox>
                                <HBox alignment="CENTER_LEFT" GridPane.columnIndex="2" GridPane.rowIndex="2">
                                    <CheckBox fx:id="chkListaNegra" mnemonicParsing="false" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;" text="Usuario en Lista Negra" />
                                </HBox>
                            </children>
                        </GridPane>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
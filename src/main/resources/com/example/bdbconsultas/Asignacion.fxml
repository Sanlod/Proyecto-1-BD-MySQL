<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="750.0" prefWidth="750.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.bdbconsultas.AsignacionController">
    <children>
        <ScrollPane fitToWidth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" style="-fx-background-color: transparent;">
            <content>
                <VBox alignment="TOP_CENTER" spacing="15.0" style="-fx-padding: 20;">
                    <children>
                        <Text text="Asignar Mascota a Casa Cuna">
                            <font><Font name="System Bold" size="22.0"/></font>
                        </Text>

                        <Separator/>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="1. Selecciona una mascota sin casa cuna:" style="-fx-font-weight: bold;"/>
                                <TableView fx:id="tblMascotas" prefHeight="150.0" prefWidth="640.0">
                                    <columns>
                                        <TableColumn fx:id="colMascotaId" prefWidth="50" text="ID"/>
                                        <TableColumn fx:id="colMascotaNombre" prefWidth="150" text="Nombre"/>
                                        <TableColumn fx:id="colMascotaRaza" prefWidth="150" text="Raza"/>
                                        <TableColumn fx:id="colMascotaTamano" prefWidth="100" text="Tamaño"/>
                                        <TableColumn fx:id="colMascotaEnergia" prefWidth="100" text="ID Energía"/>
                                    </columns>
                                </TableView>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <Label fx:id="lblMascotaSeleccionada" text="Ninguna seleccionada" style="-fx-font-style: italic;"/>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button fx:id="btnBuscarCasas" onAction="#buscarCasasCompatibles" prefHeight="32" prefWidth="200" text="Buscar Casas Compatibles" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <Separator/>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="2. Selecciona una casa cuna compatible:" style="-fx-font-weight: bold;"/>
                                <TableView fx:id="tblCasas" prefHeight="150.0" prefWidth="640.0">
                                    <columns>
                                        <TableColumn fx:id="colCasaId" prefWidth="60" text="ID Casa"/>
                                        <TableColumn fx:id="colCasaTamanos" prefWidth="300" text="Tamaños Aceptados"/>
                                        <TableColumn fx:id="colCasaDistrito" prefWidth="100" text="ID Distrito"/>
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <Separator/>

                        <VBox spacing="8.0">
                            <children>
                                <Label text="3. Mascotas con casa cuna asignada:" style="-fx-font-weight: bold;"/>
                                <TableView fx:id="tblMascotasConCasa" prefHeight="150.0" prefWidth="640.0">
                                    <columns>
                                        <TableColumn fx:id="colMascotaConCasaId" prefWidth="50" text="ID"/>
                                        <TableColumn fx:id="colMascotaConCasaNombre" prefWidth="150" text="Nombre"/>
                                        <TableColumn fx:id="colMascotaConCasaRaza" prefWidth="150" text="Raza"/>
                                        <TableColumn fx:id="colMascotaConCasaTamano" prefWidth="100" text="Tamaño"/>
                                        <TableColumn fx:id="colMascotaConCasaEnergia" prefWidth="100" text="ID Energía"/>
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" alignment="CENTER" style="-fx-background-color: #f4f4f4; -fx-padding: 15; -fx-background-radius: 10;">
                            <children>
                                <Button fx:id="btnQuitarAsignacion" onAction="#quitarAsignacion" prefHeight="35" prefWidth="220" text="🗑 Quitar Asignación" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" />
                                <HBox alignment="CENTER" spacing="20.0">
                                    <children>
                                        <Button fx:id="btnAsignar" onAction="#asignarMascota" prefHeight="40" prefWidth="200" text="✅ Confirmar Asignación" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" />
                                        <Button onAction="#cancelar" prefHeight="40" prefWidth="120" text="Volver" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
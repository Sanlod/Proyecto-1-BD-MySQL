<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="900.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.bdbconsultas.AsignacionController">
    <children>
        <VBox alignment="TOP_CENTER" layoutX="30.0" layoutY="20.0" spacing="12.0"
              AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0">
            <children>
                <Text text="Asignar Mascota a Casa Cuna">
                    <font><Font name="System Bold" size="22.0"/></font>
                </Text>

                <Separator/>

                <Label text="1. Selecciona una mascota sin casa cuna:" style="-fx-font-weight: bold;"/>
                <TableView fx:id="tblMascotas" prefHeight="180.0" prefWidth="640.0">
                    <columns>
                        <TableColumn fx:id="colMascotaId"      prefWidth="50"  text="ID"/>
                        <TableColumn fx:id="colMascotaNombre"  prefWidth="150" text="Nombre"/>
                        <TableColumn fx:id="colMascotaRaza"    prefWidth="150" text="Raza"/>
                        <TableColumn fx:id="colMascotaTamano"  prefWidth="100" text="Tamaño"/>
                        <TableColumn fx:id="colMascotaEnergia" prefWidth="100" text="ID Energía"/>
                    </columns>
                </TableView>

                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>
                        <Label fx:id="lblMascotaSeleccionada" text="Ninguna seleccionada"
                               style="-fx-font-style: italic;"/>
                        <Button fx:id="btnBuscarCasas" text="Buscar Casas Compatibles"
                                onAction="#buscarCasasCompatibles" prefHeight="32" prefWidth="200"/>
                    </children>
                </HBox>

                <Separator/>

                <Label text="2. Selecciona una casa cuna compatible:" style="-fx-font-weight: bold;"/>
                <TableView fx:id="tblCasas" prefHeight="180.0" prefWidth="640.0">
                    <columns>
                        <TableColumn fx:id="colCasaId"       prefWidth="60"  text="ID Casa"/>
                        <TableColumn fx:id="colCasaTamanos"  prefWidth="300" text="Tamaños Aceptados"/>
                        <TableColumn fx:id="colCasaDistrito" prefWidth="100" text="ID Distrito"/>
                    </columns>
                </TableView>

                <Separator/>

                <Label text="3. Mascotas con casa cuna asignada:" style="-fx-font-weight: bold;"/>
                <TableView fx:id="tblMascotasConCasa" prefHeight="180.0" prefWidth="640.0">
                    <columns>
                        <TableColumn fx:id="colMascotaConCasaId"      prefWidth="50"  text="ID"/>
                        <TableColumn fx:id="colMascotaConCasaNombre"  prefWidth="150" text="Nombre"/>
                        <TableColumn fx:id="colMascotaConCasaRaza"    prefWidth="150" text="Raza"/>
                        <TableColumn fx:id="colMascotaConCasaTamano"  prefWidth="100" text="Tamaño"/>
                        <TableColumn fx:id="colMascotaConCasaEnergia" prefWidth="100" text="ID Energía"/>
                    </columns>
                </TableView>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button fx:id="btnQuitarAsignacion" text="Quitar Asignación"
                                onAction="#quitarAsignacion" prefHeight="35" prefWidth="180"/>
                    </children>
                </HBox>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button fx:id="btnAsignar" text="Confirmar Asignación"
                                onAction="#asignarMascota" prefHeight="35" prefWidth="180"/>
                        <Button text="Volver" onAction="#cancelar" prefHeight="35" prefWidth="120"/>
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.EstadisticasAdoptionController">

    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

    <top>
        <VBox spacing="20">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
                    <children>
                        <VBox>
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Estadísticas de Adopciones" />
                                <Label style="-fx-text-fill: #e8f8f5; -fx-font-size: 12px;" text="Seguimiento de procesos y efectividad" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#switchVolver" prefWidth="90.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="↩ Volver" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <children>
                        <VBox spacing="2">
                            <Label text="Desde" style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" />
                            <DatePicker fx:id="dpStartDate" prefWidth="130" />
                        </VBox>
                        <VBox spacing="2">
                            <Label text="Hasta" style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" />
                            <DatePicker fx:id="dpEndDate" prefWidth="130" />
                        </VBox>
                        <VBox spacing="2">
                            <Label text="Tipo" style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" />
                            <ComboBox fx:id="cbPetType" prefWidth="130" />
                        </VBox>
                        <VBox spacing="2">
                            <Label text="Raza" style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" />
                            <ComboBox fx:id="cbBreed" prefWidth="130" />
                        </VBox>
                        <Button onAction="#onFilter" prefHeight="35.0" prefWidth="90.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="🔍 Filtrar">
                            <HBox.margin><Insets top="12" /></HBox.margin>
                        </Button>
                    </children>
                </HBox>

                <HBox spacing="15">
                    <children>
                        <VBox alignment="CENTER_LEFT" prefWidth="250" spacing="5" style="-fx-background-color: white; -fx-border-color: #1D9E75; -fx-border-width: 0 0 0 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="EXITOSAS" />
                            <Label fx:id="lblSuccessTotal" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1D9E75;" text="0" />
                            <Label fx:id="lblSuccessPct" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="0%" />
                        </VBox>
                        <VBox alignment="CENTER_LEFT" prefWidth="250" spacing="5" style="-fx-background-color: white; -fx-border-color: #BA7517; -fx-border-width: 0 0 0 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="EN ESPERA" />
                            <Label fx:id="lblWaitingTotal" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #BA7517;" text="0" />
                            <Label fx:id="lblWaitingPct" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="0%" />
                        </VBox>
                        <VBox alignment="CENTER_LEFT" prefWidth="250" spacing="5" style="-fx-background-color: white; -fx-border-color: #534AB7; -fx-border-width: 0 0 0 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="TOTAL GESTIONADO" />
                            <Label fx:id="lblGrandTotal" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #534AB7;" text="0" />
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <HBox spacing="20">
            <children>
                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Detalle de Estados" />
                        <TableView fx:id="tblStats" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colStatus" prefWidth="150" text="Estado" />
                                <TableColumn fx:id="colTotal" prefWidth="100" text="Cantidad" />
                                <TableColumn fx:id="colPercent" prefWidth="100" text="\%" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Distribución Visual" />
                        <PieChart fx:id="pieChart" animated="false" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
            <BorderPane.margin><Insets top="20" /></BorderPane.margin>
        </HBox>
    </center>

</BorderPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.EstadisticasDonacionController">

    <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

    <top>
        <VBox spacing="20">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
                    <children>
                        <VBox>
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Estadísticas de Donaciones" />
                                <Label style="-fx-text-fill: #e8f8f5; -fx-font-size: 12px;" text="Resumen de aportes y recompensas por entidad" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#switchVolver" prefWidth="90.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="↩ Volver" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <children>
                        <VBox spacing="2">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Desde" />
                            <DatePicker fx:id="dpStartDate" prefWidth="150" />
                        </VBox>
                        <VBox spacing="2">
                            <Label style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;" text="Hasta" />
                            <DatePicker fx:id="dpEndDate" prefWidth="150" />
                        </VBox>
                        <Button onAction="#onFilter" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="🔍 Filtrar">
                            <HBox.margin><Insets top="12" /></HBox.margin>
                        </Button>
                    </children>
                </HBox>

                <HBox spacing="15">
                    <children>
                        <VBox alignment="CENTER_LEFT" prefWidth="300" spacing="5" style="-fx-background-color: white; -fx-border-color: #378ADD; -fx-border-width: 0 0 0 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="TOTAL ASOCIACIONES" />
                            <Label fx:id="lblAssociationTotal" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #378ADD;" text="0" />
                            <Label fx:id="lblAssociationPct" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="0%" />
                        </VBox>
                        <VBox alignment="CENTER_LEFT" prefWidth="300" spacing="5" style="-fx-background-color: white; -fx-border-color: #1D9E75; -fx-border-width: 0 0 0 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="TOTAL RESCATISTAS" />
                            <Label fx:id="lblRescuerTotal" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1D9E75;" text="0" />
                            <Label fx:id="lblRescuerPct" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="0%" />
                        </VBox>
                        <VBox alignment="CENTER_LEFT" prefWidth="300" spacing="5" style="-fx-background-color: white; -fx-border-color: #534AB7; -fx-border-width: 0 0 0 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="TOTAL GENERAL" />
                            <Label fx:id="lblGrandTotal" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #534AB7;" text="0" />
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <HBox spacing="20">
            <children>
                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Desglose de Entidades" />
                        <TableView fx:id="tblStats" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colName" prefWidth="180" text="Nombre" />
                                <TableColumn fx:id="colType" prefWidth="110" text="Tipo" />
                                <TableColumn fx:id="colTotal" prefWidth="100" text="Total" />
                                <TableColumn fx:id="colPercent" prefWidth="90" text="\%" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <VBox alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Distribución de Aportes" />
                        <BarChart fx:id="barChart" animated="false" VBox.vgrow="ALWAYS">
                            <xAxis><CategoryAxis fx:id="xAxis" label="Entidad" side="BOTTOM" /></xAxis>
                            <yAxis><NumberAxis fx:id="yAxis" label="Total" side="LEFT" /></yAxis>
                        </BarChart>
                    </children>
                </VBox>
            </children>
            <BorderPane.margin><Insets top="20" /></BorderPane.margin>
        </HBox>
    </center>

</BorderPane>
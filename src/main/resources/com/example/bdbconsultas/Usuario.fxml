<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="900.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.UsuarioController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                    <children>
                        <VBox alignment="CENTER_LEFT">
                            <children>
                                <Label style="-fx-text-fill: #2c3e50; -fx-font-size: 24px; -fx-font-weight: bold;" text="Portal del Adoptante" />
                                <Label style="-fx-text-fill: #7f8c8d; -fx-font-size: 13px;" text="Bienvenido, gestiona tus solicitudes y consultas aquí" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#switchVolver" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Cerrar Sesión" />
                    </children>
                </HBox>

                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>

                        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="GESTIÓN DE MASCOTAS" />
                                <FlowPane hgap="15.0" vgap="15.0">
                                    <children>
                                        <Button onAction="#switchBuscarMascotas" prefHeight="100.0" prefWidth="130.0" style="-fx-background-color: white; -fx-border-color: #3498db; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #2980b9; -fx-font-weight: bold; -fx-cursor: hand;" text="🔎 Buscar&#10;Mascota" textAlignment="CENTER" />
                                        <Button onAction="#switchAdoptar" prefHeight="100.0" prefWidth="130.0" style="-fx-background-color: white; -fx-border-color: #27ae60; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #27ae60; -fx-font-weight: bold; -fx-cursor: hand;" text="🏠 Adoptar" textAlignment="CENTER" />
                                        <Button onAction="#switchDonar" prefHeight="100.0" prefWidth="130.0" style="-fx-background-color: white; -fx-border-color: #f1c40f; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #f39c12; -fx-font-weight: bold; -fx-cursor: hand;" text="💰 Donar" textAlignment="CENTER" />
                                        <Button onAction="#switchCasaCuna" prefHeight="100.0" prefWidth="130.0" style="-fx-background-color: white; -fx-border-color: #8e44ad; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #8e44ad; -fx-font-weight: bold; -fx-cursor: hand;" text="Casas&#10;Cuna" textAlignment="CENTER" />
                                        <Button onAction="#switchSalud" prefHeight="100.0" prefWidth="130.0" style="-fx-background-color: white; -fx-border-color: #e74c3c; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #c0392b; -fx-font-weight: bold; -fx-cursor: hand;" text="Salud" textAlignment="CENTER" />
                                        <Button onAction="#switchReportar" prefHeight="100.0" prefWidth="130.0" style="-fx-background-color: white; -fx-border-color: #e67e22; -fx-border-radius: 10; -fx-background-radius: 10; -fx-text-fill: #d35400; -fx-font-weight: bold; -fx-cursor: hand;" text="⚠️ Reportar" textAlignment="CENTER" />
                                    </children>
                                </FlowPane>

                                <Label style="-fx-font-weight: bold; -fx-text-fill: #34495e;" text="CONSULTAS Y REPORTES">
                                    <VBox.margin><Insets top="10.0" /></VBox.margin>
                                </Label>
                                <HBox spacing="10.0">
                                    <children>
                                        <Button onAction="#switchBlackList" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold;" text="🚫 Lista Negra" />
                                        <Button onAction="#switchSinAdoptar" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold;" text="📅 Sin Adoptar" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox prefWidth="250.0" spacing="12.0" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-background-radius: 15;">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Estadísticas de Interés" />
                                <Button maxWidth="Infinity" onAction="#switchEstadisticas" style="-fx-background-color: white;" text="📊 Generales" />
                                <Button maxWidth="Infinity" onAction="#switchEstadisticasAdopciones" style="-fx-background-color: white;" text="📊 Adopciones" />
                                <Button maxWidth="Infinity" onAction="#switchEstadisticasMatches" style="-fx-background-color: white;" text="📊 Matches" />
                                <Button maxWidth="Infinity" onAction="#switchEstadisticasDonacion" style="-fx-background-color: white;" text="📊 Donaciones" />
                                <Button maxWidth="Infinity" onAction="#switchEstadisticasZona" style="-fx-background-color: white;" text="📊 Por Zona" />

                                <Region VBox.vgrow="ALWAYS" />

                                <VBox spacing="5.0" style="-fx-background-color: #dfe6e9; -fx-padding: 10; -fx-background-radius: 10;">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 11px;" text="Resumen de cuenta" />
                                        <Label style="-fx-font-size: 10px;" text="Última actividad: Hoy" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.AdminController">
    <children>
        <Text layoutX="14.0" layoutY="27.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Panel de Administración" />

        <Button layoutX="50.0" layoutY="80.0" mnemonicParsing="false" onAction="#switchRegistrarMascota" text="Registrar mascota" />
        <Button layoutX="200.0" layoutY="80.0" mnemonicParsing="false" onAction="#switchAdopciones" text="Adopciones" />
        <Button layoutX="350.0" layoutY="80.0" mnemonicParsing="false" onAction="#switchDonaciones" text="Donaciones" />

        <Button layoutX="50.0" layoutY="150.0" mnemonicParsing="false" onAction="#switchMatches" text="Matches" />
        <Button layoutX="150.0" layoutY="150.0" mnemonicParsing="false" onAction="#switchPersonas" text="Personas" />
        <Button layoutX="250.0" layoutY="150.0" mnemonicParsing="false" text="Bitácoras" />
        <Button layoutX="350.0" layoutY="150.0" mnemonicParsing="false" onAction="#switchCatalogos" text="Catálogos" />
        <Button layoutX="350.0" layoutY="150.0" mnemonicParsing="false" onAction="#Recompensas" text="Recompensas" />

        <Button layoutX="480.0" layoutY="10.0" mnemonicParsing="false" onAction="#switchVolver" text="Cerrar sesión" />
    </children>
</AnchorPane>

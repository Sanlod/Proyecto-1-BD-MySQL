<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.DonarController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>

            <HBox alignment="CENTER_LEFT" prefHeight="80.0" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 10, 0, 0, 5);">
               <children>
                  <VBox>
                     <children>
                        <Label text="Realizar Donación" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />
                        <Label text="Apoya a las asociaciones registradas" style="-fx-text-fill: #e8f8f5; -fx-font-size: 12px;" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#switchVolver" prefWidth="100.0" style="-fx-background-color: rgba(255,255,255,0.25); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="↩ Volver" />
               </children>
            </HBox>

            <StackPane VBox.vgrow="ALWAYS">
               <children>
                  <AnchorPane maxWidth="600.0" prefHeight="350.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 15, 0, 0, 5); -fx-padding: 30;">
                     <children>

                        <VBox layoutX="40.0" layoutY="40.0" spacing="15.0">
                           <children>
                              <Label text="Selección de Asociaciones" style="-fx-font-weight: bold; -fx-text-fill: #16a085; -fx-font-size: 15px;" />
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Asociación Principal" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
                                    <ComboBox fx:id="aso1" prefWidth="220.0" promptText="Seleccionar..." />
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Segunda Opción" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
                                    <ComboBox fx:id="aso2" prefWidth="220.0" />
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Tercera Opción" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
                                    <ComboBox fx:id="aso3" prefWidth="220.0" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>

                        <VBox layoutX="320.0" layoutY="40.0" spacing="15.0">
                           <children>
                              <Label text="Detalles del Aporte" style="-fx-font-weight: bold; -fx-text-fill: #16a085; -fx-font-size: 15px;" />
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Monto a Donar" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
                                    <Spinner fx:id="monto" editable="true" prefWidth="220.0" />
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Divisa" style="-fx-text-fill: #7f8c8d; -fx-font-size: 11px;" />
                                    <ComboBox fx:id="divisa" prefWidth="220.0" />
                                 </children>
                              </VBox>

                              <Region prefHeight="20.0" />

                              <Button fx:id="donar" onAction="#donar" prefHeight="50.0" prefWidth="220.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(39, 174, 96, 0.3), 10, 0, 0, 4);" text="❤ EFECTUAR DONACIÓN" />
                           </children>
                        </VBox>

                     </children>
                  </AnchorPane>
               </children>
            </StackPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
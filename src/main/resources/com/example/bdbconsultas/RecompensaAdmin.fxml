<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="580.0" prefWidth="860.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.bdbconsultas.RecompensaAdminController">
    <children>

        <Button fx:id="btnVolver" layoutX="800.0" layoutY="10.0"
                text="Volver" onAction="#onVolver"/>

        <Text layoutX="20.0" layoutY="40.0" text="Mascotas perdidas"/>

        <TableView fx:id="tblMascotasPerdidas" layoutX="20.0" layoutY="45.0"
                   prefHeight="320.0" prefWidth="820.0"/>

        <Label fx:id="lblTotal" layoutX="20.0" layoutY="375.0" text="Total: 0"/>

        <Text layoutX="20.0" layoutY="415.0" text="Persona que encontró:"/>
        <ComboBox fx:id="cmbPersonaEncontro" layoutX="160.0" layoutY="398.0" prefWidth="200.0"/>
        <Button fx:id="btnAsignarPersona" layoutX="375.0" layoutY="398.0"
                text="Marcar hallada — pagar a persona"
                onAction="#onAsignarPersona"/>

        <Text layoutX="20.0" layoutY="455.0" text="Asociación:"/>
        <ComboBox fx:id="cmbAsociacion" layoutX="100.0" layoutY="438.0" prefWidth="200.0"/>
        <Button fx:id="btnDonarAsociacion" layoutX="315.0" layoutY="438.0"
                text="Marcar hallada — donar a asociación"
                onAction="#onDonarAsociacion"/>

    </children>
</AnchorPane>
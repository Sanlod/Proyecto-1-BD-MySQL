<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.RecompensaAdminController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
            <children>

                <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
                    <children>
                        <VBox>
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Administración de Recompensas" />
                                <Label style="-fx-text-fill: #e8f8f5; -fx-font-size: 12px;" text="Gestión de pagos y donaciones de bounties" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnVolver" onAction="#switchVolver" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="↩ Volver" />
                    </children>
                </HBox>

                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" VBox.vgrow="ALWAYS">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Mascotas con Recompensa Pendiente" />
                        <TableView fx:id="tblMascotasPerdidas" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f8f9f9; -fx-padding: 10; -fx-background-radius: 5;">
                            <children>
                                <Label fx:id="lblTotal" style="-fx-font-weight: bold; -fx-text-fill: #16a085; -fx-font-size: 14px;" text="Monto a liquidar: $0.00" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox spacing="15.0">
                    <children>

                        <VBox spacing="12.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #27ae60; -fx-border-width: 0 0 0 4; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 14px;" text="Opción 1: Liquidar a Rescatista" />

                                <VBox spacing="5">
                                    <Label style="-fx-font-size: 11px; -fx-text-fill: #34495e;" text="Seleccionar Rescatista Beneficiario:" />
                                    <ComboBox fx:id="cmbRescatistas" maxWidth="Infinity" promptText="Seleccionar rescatista..." />
                                </VBox>

                                <Region VBox.vgrow="ALWAYS" />
                                <Button fx:id="btnPagarRescatista" maxWidth="Infinity" onAction="#onPagarRescatista" prefHeight="40.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="💰 Pagar Recompensa" />
                            </children>
                        </VBox>

                        <VBox spacing="12.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #2980b9; -fx-border-width: 0 0 0 4; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 14px;" text="Opción 2: Donación a Asociación" />

                                <VBox spacing="5">
                                    <Label style="-fx-font-size: 11px; -fx-text-fill: #34495e;" text="Seleccionar Asociación Destino:" />
                                    <ComboBox fx:id="cmbAsociacion" maxWidth="Infinity" promptText="Seleccionar asociación..." />
                                </VBox>

                                <Region VBox.vgrow="ALWAYS" />
                                <Button fx:id="btnDonarAsociacion" maxWidth="Infinity" onAction="#onDonarAsociacion" prefHeight="40.0" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="🤝 Donar a Asociación" />
                            </children>
                        </VBox>

                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.RecompensaAdminController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
            <children>

                <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
                    <children>
                        <VBox>
                            <children>
                                <Label text="Administración de Recompensas" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />
                                <Label text="Gestión de bounties activos y transferencias" style="-fx-text-fill: #e8f8f5; -fx-font-size: 12px;" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnVolver" onAction="#switchVolver" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="↩ Volver" />
                    </children>
                </HBox>

                <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <children>
                        <Label text="Mascotas perdidas con bounty activo" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        <TableView fx:id="tblMascotasPerdidas" style="-fx-selection-bar: #e8f8f5;" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                            <children>
                                <Label fx:id="lblTotal" text="Total: 0" style="-fx-font-weight: bold; -fx-text-fill: #16a085;" />
                                <Separator orientation="VERTICAL" prefHeight="20.0" />
                                <Label fx:id="lblRescatista" text="Rescatista: —" style="-fx-text-fill: #7f8c8d;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <HBox spacing="15.0">
                    <children>
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #27ae60; -fx-border-width: 0 0 0 4;" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Pago Directo" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                <Text text="Liquidar la recompensa al rescatista que realizó el match exitoso." wrappingWidth="250.0" style="-fx-fill: #7f8c8d; -fx-font-size: 11px;" />
                                <Button fx:id="btnPagarRescatista" maxWidth="Infinity" onAction="#onPagarRescatista" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="💰 Pagar Bounty al Rescatista" />
                            </children>
                        </VBox>

                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #2980b9; -fx-border-width: 0 0 0 4;" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Donar a Asociación" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                                <GridPane hgap="10.0" vgap="10.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" minWidth="80.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    <children>
                                        <Label text="Asociación:" />
                                        <ComboBox fx:id="cmbAsociacion" maxWidth="Infinity" GridPane.columnIndex="1" promptText="Seleccionar asociación..." />

                                        <Label text="Rescatista:" GridPane.rowIndex="1" />
                                        <ComboBox fx:id="cmbRescatistas" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1" promptText="Seleccionar rescatista..." />
                                    </children>
                                </GridPane>
                                <Button fx:id="btnDonarAsociacion" maxWidth="Infinity" onAction="#onDonarAsociacion" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;" text="🤝 Donar Bounty a Asociación" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
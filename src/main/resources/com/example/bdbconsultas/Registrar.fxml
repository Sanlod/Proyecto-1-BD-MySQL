<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.RegistrarController">
    <children>
        <VBox alignment="TOP_CENTER" layoutX="50.0" layoutY="20.0" prefWidth="400.0" spacing="20.0">
            <children>
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Registro de Usuario">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Text>

                <GridPane hgap="10.0" vgap="15.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="180.0" minWidth="10.0" prefWidth="130.0" />
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="260.0" minWidth="10.0" prefWidth="250.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="20.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="Primer Nombre:" GridPane.rowIndex="0" />
                        <TextField fx:id="txtFirstName" promptText="Ej: Juan" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Segundo Nombre:" GridPane.rowIndex="1" />
                        <TextField fx:id="txtSecondName" promptText="(Opcional)" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Primer Apellido:" GridPane.rowIndex="2" />
                        <TextField fx:id="txtFirstSurname" promptText="Ej: Pérez" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Segundo Apellido:" GridPane.rowIndex="3" />
                        <TextField fx:id="txtSecondSurname" promptText="Lopez" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Separator prefWidth="200.0" GridPane.columnSpan="2" GridPane.rowIndex="4" />

                        <Label text="Correo:" GridPane.rowIndex="5" />
                        <TextField fx:id="txtEmail" promptText="usuario@correo.com" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                        <Label text="Usuario:" GridPane.rowIndex="6" />
                        <TextField fx:id="txtUsername" promptText="juanperez123" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                        <Label text="Contraseña:" GridPane.rowIndex="7" />
                        <PasswordField fx:id="txtPassword" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                        <Label text="Confirmar Contraseña:" GridPane.rowIndex="8" />
                        <PasswordField fx:id="txtConfirmPassword" GridPane.columnIndex="1" GridPane.rowIndex="8" />
                    </children>
                </GridPane>

                <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#onRegistrar" prefHeight="40.0" prefWidth="220.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="Crear Cuenta">
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>

                <Button fx:id="btnVolver" layoutX="150.0" layoutY="520.0" onAction="#onVolverClick" prefWidth="200.0" text="Volver al Login" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold;" />
            </children>
            <padding>
                <Insets bottom="20.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="550.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.RegistrarController">
    <children>
        <VBox alignment="TOP_CENTER" spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <VBox alignment="CENTER" prefHeight="100.0" spacing="5.0" style="-fx-background-color: #16a085;">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="Registro de Usuario" />
                        <Label style="-fx-text-fill: #e8f8f5; -fx-font-size: 12px;" text="Crea tu cuenta para acceder al sistema" />
                    </children>
                </VBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f4f7f6;" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="20.0" style="-fx-padding: 30;">
                            <children>

                                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #16a085;" text="Información Personal" />
                                        <GridPane hgap="15.0" vgap="15.0">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                            </columnConstraints>
                                            <children>
                                                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                                    <Label text="Primer Nombre" />
                                                    <TextField fx:id="txtFirstName" prefHeight="35.0" promptText="Ej: Juan" />
                                                </VBox>
                                                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                    <Label text="Segundo Nombre" />
                                                    <TextField fx:id="txtSecondName" prefHeight="35.0" promptText="(Opcional)" />
                                                </VBox>
                                                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                                    <Label text="Primer Apellido" />
                                                    <TextField fx:id="txtFirstSurname" prefHeight="35.0" promptText="Ej: Pérez" />
                                                </VBox>
                                                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                                    <Label text="Segundo Apellido" />
                                                    <TextField fx:id="txtSecondSurname" prefHeight="35.0" promptText="Lopez" />
                                                </VBox>
                                            </children>
                                            <rowConstraints>
                                                <RowConstraints />
                                                <RowConstraints />
                                            </rowConstraints>
                                        </GridPane>
                                    </children>
                                </VBox>

                                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2980b9;" text="Cuenta y Seguridad" />
                                        <VBox spacing="10">
                                            <children>
                                                <Label text="Correo Electrónico" />
                                                <TextField fx:id="txtEmail" prefHeight="35.0" promptText="usuario@correo.com" />

                                                <Label text="Nombre de Usuario" />
                                                <TextField fx:id="txtUsername" prefHeight="35.0" promptText="juanperez123" />

                                                <HBox spacing="15">
                                                    <children>
                                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                                            <Label text="Contraseña" />
                                                            <PasswordField fx:id="txtPassword" prefHeight="35.0" />
                                                        </VBox>
                                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                                            <Label text="Confirmar" />
                                                            <PasswordField fx:id="txtConfirmPassword" prefHeight="35.0" />
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>

                                <VBox alignment="CENTER" spacing="15.0">
                                    <children>
                                        <Button fx:id="btnRegistrar" maxWidth="Infinity" mnemonicParsing="false" onAction="#onRegistrar" prefHeight="45.0" style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 8; -fx-cursor: hand;" text="CREAR MI CUENTA" />
                                        <Button fx:id="btnVolver" onAction="#onVolverClick" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-cursor: hand;" text="← Volver al Login" underline="true" />
                                    </children>
                                    <padding>
                                        <Insets top="10.0" />
                                    </padding>
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
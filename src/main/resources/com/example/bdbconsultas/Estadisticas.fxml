<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.EstadisticasController">

   <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>

   <top>
      <VBox spacing="20" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
               <children>
                  <VBox>
                     <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Dashboard de Estadísticas" />
                        <Label style="-fx-text-fill: #e8f8f5; -fx-font-size: 12px;" text="Análisis de población y estados de mascotas" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#switchVolver" prefWidth="90.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="↩ Volver" />
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
               <children>
                  <Label style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="Rango:" />
                  <DatePicker fx:id="dpStartDate" prefWidth="150" promptText="Desde" />
                  <DatePicker fx:id="dpEndDate" prefWidth="150" promptText="Hasta" />
                  <Button onAction="#onFilter" prefHeight="30.0" prefWidth="100.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="🔍 Filtrar" />
               </children>
            </HBox>

            <GridPane hgap="15" vgap="10">
               <columnConstraints>
                  <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="100.0" />
               </columnConstraints>
               <children>
                  <VBox fx:id="cardLost" alignment="CENTER_LEFT" spacing="5" style="-fx-background-color: white; -fx-border-color: #E24B4A; -fx-border-width: 0 0 0 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" GridPane.columnIndex="0">
                     <Label style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="PERDIDAS" />
                     <Label fx:id="lblLostTotal" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #E24B4A;" text="0" />
                     <Label fx:id="lblLostPct" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="0%" />
                  </VBox>
                  <VBox fx:id="cardFound" alignment="CENTER_LEFT" spacing="5" style="-fx-background-color: white; -fx-border-color: #1D9E75; -fx-border-width: 0 0 0 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" GridPane.columnIndex="1">
                     <Label style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="ENCONTRADAS" />
                     <Label fx:id="lblFoundTotal" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1D9E75;" text="0" />
                     <Label fx:id="lblFoundPct" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="0%" />
                  </VBox>
                  <VBox fx:id="cardAdopted" alignment="CENTER_LEFT" spacing="5" style="-fx-background-color: white; -fx-border-color: #378ADD; -fx-border-width: 0 0 0 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" GridPane.columnIndex="2">
                     <Label style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="ADOPTADAS" />
                     <Label fx:id="lblAdoptedTotal" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #378ADD;" text="0" />
                     <Label fx:id="lblAdoptedPct" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="0%" />
                  </VBox>
                  <VBox fx:id="cardInAdoption" alignment="CENTER_LEFT" spacing="5" style="-fx-background-color: white; -fx-border-color: #BA7517; -fx-border-width: 0 0 0 5; -fx-background-radius: 5; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" GridPane.columnIndex="3">
                     <Label style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="EN ADOPCIÓN" />
                     <Label fx:id="lblInAdoptionTotal" style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #BA7517;" text="0" />
                     <Label fx:id="lblInAdoptionPct" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="0%" />
                  </VBox>
               </children>
            </GridPane>
         </children>
      </VBox>
   </top>

   <center>
      <HBox spacing="20">
         <children>
            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Desglose Detallado" />
                  <TableView fx:id="tblStats" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="colType" prefWidth="120" text="Tipo" />
                        <TableColumn fx:id="colState" prefWidth="120" text="Estado" />
                        <TableColumn fx:id="colTotal" prefWidth="90" text="Cantidad" />
                        <TableColumn fx:id="colPercent" prefWidth="80" text="\%" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  <HBox alignment="CENTER_RIGHT" spacing="10">
                     <Label style="-fx-text-fill: #7f8c8d;" text="Total General:" />
                     <Label fx:id="lblGrandTotal" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="0" />
                  </HBox>
               </children>
            </VBox>

            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);" HBox.hgrow="ALWAYS">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Tendencia por Tipo" />
                  <BarChart fx:id="barChart" animated="false" VBox.vgrow="ALWAYS">
                     <xAxis><CategoryAxis fx:id="xAxis" side="BOTTOM" /></xAxis>
                     <yAxis><NumberAxis fx:id="yAxis" side="LEFT" /></yAxis>
                  </BarChart>
               </children>
            </VBox>
         </children>
         <BorderPane.margin><Insets top="20" /></BorderPane.margin>
      </HBox>
   </center>

</BorderPane>
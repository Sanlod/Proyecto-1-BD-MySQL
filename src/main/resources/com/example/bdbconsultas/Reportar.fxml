<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.ReportesController">
   <children>
      <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
         <children>

            <HBox alignment="CENTER_LEFT" prefHeight="55.0" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 8; -fx-padding: 10 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 2);">
               <children>
                  <VBox alignment="CENTER_LEFT">
                     <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Gestión de Reportes" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#switchVolver" prefWidth="80.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="↩ Volver" />
               </children>
            </HBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #f4f7f6;" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="12.0">
                     <padding>
                        <Insets bottom="5.0" left="2.0" right="10.0" top="5.0" />
                     </padding>
                     <children>

                        <VBox spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                           <children>
                              <HBox alignment="CENTER_LEFT">
                                 <children>
                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Mascotas" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblTotalMascotas" style="-fx-font-weight: bold; -fx-text-fill: #16a085;" text="0" />
                                 </children>
                              </HBox>

                              <TableView fx:id="tablaMascota" prefHeight="140.0">
                                 <columns>
                                    <TableColumn prefWidth="120.0" text="Nombre" />
                                    <TableColumn prefWidth="100.0" text="Tipo" />
                                    <TableColumn prefWidth="100.0" text="Estado" />
                                 </columns>
                                 <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                 </columnResizePolicy>
                              </TableView>

                              <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f9fbfb; -fx-padding: 8; -fx-background-radius: 5;">
                                 <children>
                                    <ComboBox fx:id="enfermedadCbx" prefWidth="200.0" promptText="Enfermedad..." />
                                    <Button onAction="#reportarEnfermo" prefHeight="30.0" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-weight: bold;" text="✚ Reportar Salud" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                        <VBox spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                           <children>
                              <HBox alignment="CENTER_LEFT">
                                 <children>
                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Personas" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblTotalPersonas" style="-fx-font-weight: bold; -fx-text-fill: #3498db;" text="0" />
                                 </children>
                              </HBox>

                              <TableView fx:id="tablaPersona" prefHeight="160.0">
                                 <columns>
                                    <TableColumn prefWidth="150.0" text="Nombre" />
                                    <TableColumn prefWidth="100.0" text="ID" />
                                    <TableColumn prefWidth="180.0" text="Email" />
                                 </columns>
                                 <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                 </columnResizePolicy>
                              </TableView>

                              <HBox spacing="10">
                                 <children>
                                    <TextArea fx:id="notas" prefHeight="60.0" promptText="Notas del reporte..." wrapText="true" HBox.hgrow="ALWAYS" />
                                    <VBox spacing="5" prefWidth="150.0">
                                       <children>
                                          <Spinner fx:id="calificacion" editable="true" />
                                          <HBox spacing="5">
                                             <children>
                                                <Button maxWidth="1.7976931348623157E308" onAction="#reportarPersona" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 11px;" text="Reportar" HBox.hgrow="ALWAYS" />
                                                <Button maxWidth="1.7976931348623157E308" onAction="#denunciarPersona" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-font-size: 11px;" text="Denunciar" HBox.hgrow="ALWAYS" />
                                             </children>
                                          </HBox>
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
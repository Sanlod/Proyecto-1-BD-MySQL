<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.Hyperlink?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.LogInController">
    <children>
        <Text layoutX="254.0" layoutY="60.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Iniciar Sesión">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Text>

        <Text layoutX="140.0" layoutY="145.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Usuario:" />
        <Text layoutX="140.0" layoutY="196.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Contraseña:" />

        <TextField fx:id="txtUsuario" layoutX="226.0" layoutY="128.0" prefHeight="25.0" prefWidth="200.0" promptText="Ingrese su usuario" />

        <PasswordField fx:id="txtContrasena" layoutX="226.0" layoutY="179.0" prefHeight="25.0" prefWidth="200.0" promptText="Ingrese su contraseña" />

        <Button fx:id="btnLogin" onAction="#onLogin" layoutX="268.0" layoutY="250.0" mnemonicParsing="false" prefHeight="30.0" prefWidth="100.0" text="Ingresar" />
        <Hyperlink fx:id="lnkRegistrar" onAction="#onRegistrarseClick" layoutX="245.0" layoutY="300.0" text="¿No tienes cuenta? Regístrate"></Hyperlink>
    </children>
</AnchorPane>
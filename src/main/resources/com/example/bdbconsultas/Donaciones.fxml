<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.DonacionesController">
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
         <children>

            <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
               <children>
                  <VBox>
                     <children>
                        <Label text="Consulta de Donaciones" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
                        <Label text="Filtrado y visualización de aportes recibidos" style="-fx-text-fill: #e8f8f5; -fx-font-size: 11px;" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#switchVolver" prefWidth="90.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="↩ Volver" />
               </children>
            </HBox>

            <AnchorPane prefHeight="140.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2); -fx-padding: 15;">
               <children>
                  <HBox alignment="CENTER" spacing="25.0" AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="10.0">
                     <children>
                        <VBox spacing="5">
                           <children>
                              <Label text="Desde" style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-font-size: 11px;" />
                              <DatePicker fx:id="dpDesde" prefWidth="170.0" />
                           </children>
                        </VBox>
                        <VBox spacing="5">
                           <children>
                              <Label text="Hasta" style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-font-size: 11px;" />
                              <DatePicker fx:id="dpHasta" prefWidth="170.0" />
                           </children>
                        </VBox>
                        <VBox spacing="5">
                           <children>
                              <Label text="Nombre Donador" style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-font-size: 11px;" />
                              <ComboBox fx:id="cbDonador" prefWidth="180.0" />
                           </children>
                        </VBox>
                        <VBox spacing="5">
                           <children>
                              <Label text="Asociación" style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-font-size: 11px;" />
                              <ComboBox fx:id="cbAsociacion" prefWidth="180.0" />
                           </children>
                        </VBox>
                        <Button onMouseClicked="#onBuscar" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="🔍 BUSCAR">
                           <VBox.margin>
                              <Insets top="15.0" />
                           </VBox.margin>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </AnchorPane>

            <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2);">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Label text="Resultados encontrados:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        <Label fx:id="lblResultados" text="0" style="-fx-text-fill: #16a085; -fx-font-weight: bold; -fx-font-size: 14px;" />
                     </children>
                  </HBox>
                  <TableView fx:id="tablaDonaciones" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5; -fx-border-color: #ecf0f1;">
                     <columns>
                        <TableColumn fx:id="colC1" prefWidth="400.0" text="Detalle de Donación" />
                        <TableColumn fx:id="colC2" prefWidth="400.0" text="Monto / Fecha" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="620.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.AdopcionesController">
   <children>

      <Button fx:id="btnVolver" layoutX="840.0" layoutY="10.0" onAction="#switchVolver" text="Volver" />

      <!-- Filtros -->
      <Text layoutX="30.0" layoutY="45.0" text="Desde:" />
      <DatePicker fx:id="dpDesde" layoutX="80.0" layoutY="28.0" />

      <Text layoutX="270.0" layoutY="45.0" text="Hasta:" />
      <DatePicker fx:id="dpHasta" layoutX="320.0" layoutY="28.0" />

      <Text layoutX="510.0" layoutY="45.0" text="Mascota:" />
      <ComboBox fx:id="cbMascota" layoutX="565.0" layoutY="28.0" prefWidth="150.0" />

      <Text layoutX="30.0" layoutY="85.0" text="Adoptante:" />
      <ComboBox fx:id="cbAdoptante" layoutX="100.0" layoutY="68.0" prefWidth="150.0" />

      <Button layoutX="270.0" layoutY="68.0" onAction="#onBuscar" text="Buscar" />

      <!-- Tabla adopciones (historial) -->
      <Text layoutX="30.0" layoutY="115.0" text="Adopciones" />
      <TableView fx:id="tablaAdopciones" layoutX="30.0" layoutY="120.0" prefHeight="140.0" prefWidth="840.0" />

      <Label fx:id="lblResultados" layoutX="30.0" layoutY="270.0" text="Total: 0" />

      <!-- StackPane para solicitudes con altura fija (no se estira) -->
      <Text layoutX="30.0" layoutY="295.0" text="Solicitudes" />
      <StackPane fx:id="stackPaneSolicitudes" layoutX="30.0" layoutY="305.0" maxHeight="150.0" prefHeight="150.0" prefWidth="840.0">
         <children>
            <TableView fx:id="tablaSolicitudes" visible="true" />
            <AnchorPane fx:id="panelDetalleSolicitud" prefHeight="150.0" visible="false">
               <children>
                  <Text layoutX="20" layoutY="25" style="-fx-font-weight: bold;" text="Detalle de la solicitud" />
                  <Label layoutX="20" layoutY="50" text="ID:" />
                  <Label fx:id="lblIdSolicitud" layoutX="100" layoutY="50" />
                  <Label layoutX="20" layoutY="75" text="Mascota:" />
                  <Label fx:id="lblMascota" layoutX="100" layoutY="75" />
                  <Label layoutX="20" layoutY="100" text="Adoptante:" />
                  <Label fx:id="lblAdoptante" layoutX="100" layoutY="100" />
                  <Label layoutX="20" layoutY="125" text="Estado:" />
                  <Label fx:id="lblEstado" layoutX="100" layoutY="125" />

                  <Label layoutX="20" layoutY="220" text="Preguntas y respuestas:" />
                  <ScrollPane fitToWidth="true" layoutX="20" layoutY="240" prefHeight="70" prefWidth="760">
                     <content>
                        <VBox fx:id="vboxPreguntasRespuestas" prefWidth="740" spacing="3" />
                     </content>
                  </ScrollPane>

                  <Button layoutX="20" layoutY="325" onAction="#onVolverALista" text="Volver a la lista" />
               </children>
            </AnchorPane>
         </children>
      </StackPane>

      <!-- Botones de aprobar/rechazar (actúan sobre la solicitud seleccionada) -->
      <Button fx:id="btnAprobar" layoutX="30.0" layoutY="475.0" onAction="#onAprobar" text="Aprobar seleccionada" />
      <Button fx:id="btnRechazar" layoutX="180.0" layoutY="475.0" onAction="#onRechazar" text="Rechazar seleccionada" />

   </children>
</AnchorPane>

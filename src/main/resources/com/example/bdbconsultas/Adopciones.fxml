<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import java.net.URL?>

<AnchorPane prefHeight="850.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.AdopcionesController">
   <stylesheets><URL value="@style.css" /></stylesheets>
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
         <children>

            <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 12; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
               <children>
                  <VBox>
                     <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Gestión Central de Adopciones" />
                        <Label style="-fx-text-fill: #e8f8f5; -fx-font-size: 11px;" text="Panel administrativo para control de estados, hallazgos y solicitudes" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnVolver" onAction="#switchVolver" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="↩ Volver" />
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 15; -fx-background-color: #ffffff; -fx-background-radius: 10; -fx-border-color: #d1d8e0; -fx-border-radius: 10;">
               <children>
                  <VBox spacing="4"><Label style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 10;" text="Periodo Desde:" /><DatePicker fx:id="dpDesde" prefWidth="130.0" /></VBox>
                  <VBox spacing="4"><Label style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 10;" text="Periodo Hasta:" /><DatePicker fx:id="dpHasta" prefWidth="130.0" /></VBox>
                  <VBox spacing="4"><Label style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 10;" text="Mascota:" /><ComboBox fx:id="cbMascota" prefWidth="150.0" /></VBox>
                  <VBox spacing="4"><Label style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d; -fx-font-size: 10;" text="Adoptante:" /><ComboBox fx:id="cbAdoptante" prefWidth="150.0" /></VBox>
                  <Button onAction="#onBuscar" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20;" text="🔍 Buscar" />
               </children>
            </HBox>

            <SplitPane dividerPositions="0.65" prefHeight="350.0" style="-fx-background-color: transparent; -fx-padding: 0;">
               <items>
                  <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: white; -fx-background-radius: 10;">
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <Label style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #2c3e50;" text="📜 Historial de Adopciones" />
                           <Region HBox.hgrow="ALWAYS" />
                           <Button onAction="#verFotos" style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold;" text="📷 Ver Fotos" />
                        </HBox>
                        <HBox spacing="10" VBox.vgrow="ALWAYS">
                           <children>
                              <TableView fx:id="tablaAdopciones" HBox.hgrow="ALWAYS" />
                              <VBox alignment="TOP_CENTER" spacing="5" style="-fx-background-color: #f8f9fa; -fx-padding: 5; -fx-border-color: #d1d8e0; -fx-border-radius: 5;">
                                 <children>
                                    <Label text="Entrega" style="-fx-font-size: 9; -fx-font-weight: bold;"/>
                                    <ImageView fx:id="imgFoto" fitHeight="90.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" />
                                    <Separator />
                                    <Label text="Nueva Vida" style="-fx-font-size: 9; -fx-font-weight: bold;"/>
                                    <ImageView fx:id="imgNuevaVida" fitHeight="90.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true" />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: white; -fx-background-radius: 10;">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #16a085;" text="🐾 Mascotas Halladas (Pendientes)" />
                        <TableView fx:id="tablaHalladas" VBox.vgrow="ALWAYS" />
                        <Button fx:id="btnPasarAAdopcion" onAction="#onPasarAAdopcion" maxWidth="Infinity" style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-font-weight: bold;" text="➡️ Pasar a Adopción" />
                     </children>
                  </VBox>
               </items>
            </SplitPane>

            <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: white; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                     <Label style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #f39c12;" text="📥 Solicitudes Pendientes de Revisión" />
                     <Label fx:id="lblResultados" style="-fx-font-style: italic; -fx-text-fill: #95a5a6;" text="(Total: 0 registros)" />
                  </HBox>

                  <StackPane fx:id="stackPaneSolicitudes" VBox.vgrow="ALWAYS">
                     <children>
                        <VBox fx:id="vboxTablaSolicitudes" spacing="10">
                           <children>
                              <TableView fx:id="tablaSolicitudes" VBox.vgrow="ALWAYS" />
                              <HBox alignment="CENTER" spacing="20">
                                 <children>
                                    <Button fx:id="btnAprobar" onAction="#onAprobar" prefHeight="35.0" prefWidth="200.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="✔️ Aprobar Solicitud" />
                                    <Button fx:id="btnRechazar" onAction="#onRechazar" prefHeight="35.0" prefWidth="200.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="❌ Rechazar Solicitud" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                        <AnchorPane fx:id="panelDetalleSolicitud" visible="false" style="-fx-background-color: white; -fx-border-color: #f39c12; -fx-border-width: 2; -fx-background-radius: 10;">
                           <children>
                              <VBox spacing="12.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
                                 <children>
                                    <HBox alignment="CENTER_LEFT">
                                       <Label style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #d35400;" text="Ficha Detallada de la Solicitud" />
                                       <Region HBox.hgrow="ALWAYS" />
                                       <Button onAction="#onVolverALista" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" text="⬅ Volver al listado" />
                                    </HBox>
                                    <HBox spacing="40.0" style="-fx-background-color: #fffaf0; -fx-padding: 10; -fx-background-radius: 8;">
                                       <children>
                                          <VBox><Label text="ID" style="-fx-text-fill: #7f8c8d; -fx-font-size: 10;"/><Label fx:id="lblIdSolicitud" style="-fx-font-weight: bold;"/></VBox>
                                          <VBox><Label text="MASCOTA" style="-fx-text-fill: #7f8c8d; -fx-font-size: 10;"/><Label fx:id="lblMascota" style="-fx-font-weight: bold; -fx-text-fill: #2980b9;"/></VBox>
                                          <VBox><Label text="ADOPTANTE" style="-fx-text-fill: #7f8c8d; -fx-font-size: 10;"/><Label fx:id="lblAdoptante" style="-fx-font-weight: bold;"/></VBox>
                                          <VBox><Label text="ESTADO" style="-fx-text-fill: #7f8c8d; -fx-font-size: 10;"/><Label fx:id="lblEstado" style="-fx-font-weight: bold; -fx-text-fill: #f39c12;"/></VBox>
                                       </children>
                                    </HBox>
                                    <Label text="Cuestionario de Evaluación:" style="-fx-font-weight: bold;" />
                                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                                       <VBox fx:id="vboxPreguntasRespuestas" spacing="8" style="-fx-padding: 10;" />
                                    </ScrollPane>
                                 </children>
                              </VBox>
                           </children>
                        </AnchorPane>
                     </children>
                  </StackPane>
               </children>
            </VBox>

         </children>
      </VBox>
   </children>
</AnchorPane>
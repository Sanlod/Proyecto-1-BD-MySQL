<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import java.net.URL?>

<AnchorPane prefHeight="550.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.BlackListController">
   <stylesheets>
      <URL value="@style.css" />
   </stylesheets>
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>

            <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #2c3e50, #4b79a1); -fx-background-radius: 10; -fx-padding: 15;">
               <children>
                  <VBox>
                     <children>
                        <Label text="Restricciones de Adopción" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />
                        <Label text="Registro oficial de usuarios no aptos" style="-fx-text-fill: #ecf0f1; -fx-font-size: 11px;" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#switchVolver" styleClass="button-secondary" text="↩ Volver" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold;" />
               </children>
            </HBox>

            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>

                  <VBox spacing="10.0" HBox.hgrow="ALWAYS" styleClass="card" style="-fx-padding: 10;">
                     <children>
                        <Label text="Usuarios en Lista Negra" style="-fx-font-weight: bold; -fx-text-fill: #34495e;" />
                        <TableView fx:id="tblDatos" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;">
                           <columns>
                              <TableColumn fx:id="colId" prefWidth="100.0" text="Identificación" />
                              <TableColumn fx:id="colNombreCompleto" prefWidth="300.0" text="Nombre Completo" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>

                  <VBox prefWidth="300.0" spacing="15.0" styleClass="card" style="-fx-padding: 15; -fx-border-color: #e74c3c; -fx-border-width: 0 0 0 4;">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                           <children>
                              <Label text="Expediente" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #e74c3c;" />
                           </children>
                        </HBox>
                        <Separator />

                        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                           <children>
                              <Label text="Notas del Incidente:" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                              <TextArea fx:id="txtNotas" editable="false" wrapText="true"
                                        style="-fx-control-inner-background: #fff5f5; -fx-background-radius: 8;" VBox.vgrow="ALWAYS" />
                           </children>
                        </VBox>

                        <VBox spacing="5.0">
                           <children>
                              <Label text="Nivel de Gravedad:" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                              <TextField fx:id="txtCalificacion" editable="false" alignment="CENTER"
                                         style="-fx-background-color: #fdeaea; -fx-text-fill: #c0392b; -fx-font-weight: bold; -fx-font-size: 14px; -fx-border-color: #fadbd8; -fx-border-radius: 5;" />
                           </children>
                        </VBox>

                        <VBox style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-background-radius: 5;">
                           <children>
                              <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Atención: Esta información es confidencial y solo para uso interno del refugio."
                                    wrappingWidth="250.0" style="-fx-fill: #95a5a6; -fx-font-size: 10px; -fx-font-style: italic;" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>

               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.AdoptarController">
   <stylesheets>
      <URL value="@style.css" />
   </stylesheets>
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="15.0">
         <children>

            <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #27ae60, #2ecc71); -fx-background-radius: 8; -fx-padding: 10 15;">
               <children>
                  <VBox>
                     <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Nueva Solicitud de Adopción" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#switchVolver" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;" styleClass="button-secondary" text="↩ Volver" />
               </children>
            </HBox>

            <HBox spacing="15.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox spacing="8.0" style="-fx-padding: 10;" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="🐾 1. Seleccione Mascota" />
                        <TableView fx:id="tblMascotas" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colPetId" prefWidth="60.0" text="ID" />
                              <TableColumn fx:id="colPetNombre" prefWidth="200.0" text="Nombre Mascota" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>

                  <VBox spacing="8.0" style="-fx-padding: 10;" styleClass="card" visible="false" HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="👤 2. Seleccione Adoptante" />
                        <TableView fx:id="tblAdoptantes" visible="false" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colAdopId" prefWidth="60.0" text="ID" />
                              <TableColumn fx:id="colAdopNombre" prefWidth="200.0" text="Nombre Completo" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </HBox>

            <VBox prefHeight="220.0" spacing="8.0" style="-fx-padding: 12; -fx-border-color: #3498db; -fx-border-width: 0 0 0 4;" styleClass="card">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #3498db;" text="📝 Formulario de Evaluación" />
                        <Separator HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>

                  <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: #ecf0f1; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="vboxPreguntas" spacing="12.0" style="-fx-padding: 10; -fx-background-color: #ffffff;" />
                     </content>
                  </ScrollPane>

                  <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 5 0 0 0;">
                     <children>
                        <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 11px; -fx-font-style: italic;" text="Complete todos los campos" />
                        <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#onRegistrar" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 25;" text="Registrar Solicitud" />
                     </children>
                  </HBox>
               </children>
            </VBox>

         </children>
      </VBox>
   </children>
</AnchorPane>

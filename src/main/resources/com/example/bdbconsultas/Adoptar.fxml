<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import java.net.URL?>

<AnchorPane prefHeight="700.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.AdoptarController">
   <stylesheets>
      <URL value="@style.css" />
   </stylesheets>
   <children>
      <VBox spacing="15.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="15.0">
         <children>

            <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #27ae60, #2ecc71); -fx-background-radius: 8; -fx-padding: 10 15;">
               <children>
                  <VBox>
                     <children>
                        <Label text="Nueva Solicitud de Adopción" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#switchVolver" styleClass="button-secondary"
                          style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white;" text="↩ Volver" />
               </children>
            </HBox>

            <HBox spacing="15.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox spacing="8.0" HBox.hgrow="ALWAYS" styleClass="card" style="-fx-padding: 10;">
                     <children>
                        <Label text="🐾 1. Seleccione Mascota" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        <TableView fx:id="tblMascotas" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colPetId" prefWidth="60.0" text="ID" />
                              <TableColumn fx:id="colPetNombre" prefWidth="200.0" text="Nombre Mascota" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>

                  <VBox spacing="8.0" HBox.hgrow="ALWAYS" styleClass="card" style="-fx-padding: 10;">
                     <children>
                        <Label text="👤 2. Seleccione Adoptante" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        <TableView fx:id="tblAdoptantes" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colAdopId" prefWidth="60.0" text="ID" />
                              <TableColumn fx:id="colAdopNombre" prefWidth="200.0" text="Nombre Completo" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
               </children>
            </HBox>

            <VBox spacing="8.0" prefHeight="220.0" styleClass="card" style="-fx-padding: 12; -fx-border-color: #3498db; -fx-border-width: 0 0 0 4;">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                     <children>
                        <Label text="📝 Formulario de Evaluación" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #3498db;" />
                        <Separator HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>

                  <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: #ecf0f1; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox fx:id="vboxPreguntas" spacing="12.0" style="-fx-padding: 10; -fx-background-color: #ffffff;" />
                     </content>
                  </ScrollPane>

                  <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 5 0 0 0;">
                     <children>
                        <Label text="Complete todos los campos" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px; -fx-font-style: italic;" />
                        <Button fx:id="btnRegistrar" mnemonicParsing="false" onAction="#onRegistrar"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 25;"
                                text="Registrar Solicitud" />
                     </children>
                  </HBox>
               </children>
            </VBox>

         </children>
      </VBox>
   </children>
</AnchorPane>
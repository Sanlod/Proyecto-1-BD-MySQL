<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="650.0" prefWidth="875.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.AdoptarController">
   <children>

      <Button fx:id="btnVolver" layoutX="815.0" layoutY="10.0" onAction="#switchVolver" text="Volver" />

      <Text layoutX="30.0" layoutY="89.0" text="Mascota:" />
      <ComboBox fx:id="cmbMascota" layoutX="100.0" layoutY="72.0" prefWidth="200.0" />

      <Text layoutX="320.0" layoutY="89.0" text="Adoptante:" />
      <ComboBox fx:id="cmbAdoptante" layoutX="390.0" layoutY="72.0" prefWidth="200.0" />

      <!-- Fotos req. f -->
      <Text layoutX="30.0" layoutY="168.0" text="Foto con mascota:" />
      <Button fx:id="btnFoto" layoutX="150.0" layoutY="152.0" onAction="#onSeleccionarFoto" text="Seleccionar" />
      <Label fx:id="lblFoto" layoutX="260.0" layoutY="157.0" text="Sin foto" />

      <Text layoutX="30.0" layoutY="198.0" text="Foto nueva vida:" />
      <Button fx:id="btnFotoNueva" layoutX="150.0" layoutY="182.0" onAction="#onSeleccionarFotoNueva" text="Seleccionar" />
      <Label fx:id="lblFotoNueva" layoutX="260.0" layoutY="187.0" text="Sin foto" />

      <!-- Formulario parametrizable req. o -->
      <Text layoutX="30.0" layoutY="222.0" text="Formulario de solicitud:" />
      <ScrollPane fitToWidth="true" layoutX="30.0" layoutY="228.0" prefHeight="340.0" prefWidth="840.0">
         <content>
            <VBox fx:id="vboxPreguntas" spacing="15.0" style="-fx-padding: 10;" />
         </content>
      </ScrollPane>

      <Button fx:id="btnRegistrar" layoutX="740.0" layoutY="585.0" onAction="#onRegistrar" text="Registrar solicitud" />

   </children>
</AnchorPane>

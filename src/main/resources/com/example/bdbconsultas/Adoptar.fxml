<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="650.0" prefWidth="875.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.AdoptarController">
   <children>
      <Button fx:id="btnVolver" layoutX="800.0" layoutY="14.0" onAction="#switchVolver" prefWidth="60.0" text="Volver" />

      <Label layoutX="30.0" layoutY="20.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Registro de Solicitud de Adopción" />

      <HBox layoutX="30.0" layoutY="60.0" spacing="20.0">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label text="Seleccione Mascota (En Adopción):" />
                  <TableView fx:id="tblMascotas" prefHeight="150.0" prefWidth="395.0">
                     <columns>
                        <TableColumn fx:id="colPetId" prefWidth="75.0" text="ID" />
                        <TableColumn fx:id="colPetNombre" prefWidth="318.0" text="Nombre Mascota" />
                     </columns>
                  </TableView>
               </children>
            </VBox>

            <VBox spacing="5.0">
               <children>
                  <Label text="Seleccione Adoptante:" />
                  <TableView fx:id="tblAdoptantes" prefHeight="150.0" prefWidth="395.0">
                     <columns>
                        <TableColumn fx:id="colAdopId" prefWidth="75.0" text="ID" />
                        <TableColumn fx:id="colAdopNombre" prefWidth="318.0" text="Nombre Completo" />
                     </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>

      <VBox layoutX="30.0" layoutY="235.0" spacing="10.0">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="15.0" />
            <HBox alignment="CENTER_LEFT" spacing="15.0" />
         </children>
      </VBox>

      <Label layoutX="30.0" layoutY="315.0" text="Formulario de solicitud (Responda todas las preguntas):" />
      <ScrollPane fitToWidth="true" layoutX="30.0" layoutY="335.0" prefHeight="240.0" prefWidth="815.0">
         <content>
            <VBox fx:id="vboxPreguntas" spacing="15.0" style="-fx-padding: 10;" />
         </content>
      </ScrollPane>

      <Button fx:id="btnRegistrar" layoutX="715.0" layoutY="590.0" onAction="#onRegistrar" prefHeight="30.0" prefWidth="130.0" style="-fx-base: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Registrar solicitud" />
   </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.CatalogosController">
   <children>

      <Button fx:id="btnVolver" layoutX="840.0" layoutY="14.0" onAction="#switchVolver" text="Volver" />

      <Text layoutX="24.0" layoutY="38.0" text="Entidad:" />
      <ComboBox fx:id="cmbEntidad" layoutX="24.0" layoutY="42.0" onAction="#onEntidadSeleccionada" prefWidth="160.0" />

      <ComboBox fx:id="cmbFiltroEspecial" layoutX="200.0" layoutY="42.0" prefWidth="180.0" visible="false" />

      <TextField fx:id="txtDescripcion" layoutX="395.0" layoutY="42.0" prefWidth="200.0" visible="false" />

      <TableView fx:id="tblDatos" layoutX="24.0" layoutY="80.0" prefHeight="300.0" prefWidth="854.0">
         <columns>
            <TableColumn fx:id="colC1" prefWidth="100.0" text="ID" />
            <TableColumn fx:id="colC2" prefWidth="400.0" text="Valor" />
         </columns>
      </TableView>

      <Text layoutX="24.0" layoutY="402.0" text="ID a editar:" />
      <Spinner fx:id="spnIdEditar" layoutX="24.0" layoutY="408.0" prefWidth="80.0" />

      <Text layoutX="120.0" layoutY="402.0" text="Nuevo valor:" />
      <TextField fx:id="txtNuevoValor" layoutX="120.0" layoutY="408.0" prefWidth="200.0" />

      <Button fx:id="btnEditar" layoutX="335.0" layoutY="408.0" onAction="#onEditar" text="Editar" />

      <Button fx:id="btnEliminar" layoutX="410.0" layoutY="408.0" onAction="#onEliminar" text="Eliminar" />

      <Text layoutX="24.0" layoutY="462.0" text="Valor a agregar:" />
      <TextField fx:id="txtValorAgregar" layoutX="24.0" layoutY="468.0" prefWidth="200.0" />

      <Button fx:id="btnAgregar" layoutX="240.0" layoutY="468.0" onAction="#onAgregar" text="Agregar" />

   </children>
</AnchorPane>

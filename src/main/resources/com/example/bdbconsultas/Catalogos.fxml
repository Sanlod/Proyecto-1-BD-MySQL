<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import java.net.URL?>

<AnchorPane prefHeight="650.0" prefWidth="950.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.CatalogosController">
   <stylesheets>
      <URL value="@style.css" />
   </stylesheets>
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>

            <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #16a085, #2ecc71); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
               <children>
                  <VBox>
                     <children>
                        <Label text="Gestión de Catálogos" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" />
                        <Label text="Administración de entidades y valores del sistema" style="-fx-text-fill: #e8f8f5; -fx-font-size: 12px;" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnVolver" onAction="#switchVolver" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" text="↩ Volver" />
               </children>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label text="Seleccionar Entidad:" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                        <ComboBox fx:id="cmbEntidad" onAction="#onEntidadSeleccionada" prefWidth="180.0" promptText="--- Seleccione ---" />
                     </children>
                  </VBox>

                  <VBox fx:id="vboxFiltroEspecial" spacing="5.0">
                     <children>
                        <ComboBox fx:id="cmbFiltroEspecial" prefWidth="200.0" visible="false" />
                     </children>
                  </VBox>

                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <TextField fx:id="txtDescripcion" prefHeight="30.0" promptText="Buscar descripción..." visible="false" style="-fx-background-radius: 5;" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <TableView fx:id="tblDatos" VBox.vgrow="ALWAYS" style="-fx-selection-bar: #e8f8f5;">
               <columns>
                  <TableColumn fx:id="colC1" prefWidth="120.0" text="ID Identificador" />
                  <TableColumn fx:id="colC2" prefWidth="600.0" text="Valor / Descripción del Registro" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>

            <HBox spacing="15.0">
               <children>
                  <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #d1d8e0; -fx-border-width: 1;" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Edición de Registros" style="-fx-font-weight: bold; -fx-text-fill: #16a085;" />
                        <Separator />
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="ID a editar:" style="-fx-font-size: 11px;" />
                                    <Spinner fx:id="spnIdEditar" prefWidth="90.0" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label text="Nuevo Valor:" style="-fx-font-size: 11px;" />
                                    <TextField fx:id="txtNuevoValor" promptText="Ingrese el nuevo texto..." />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <Button fx:id="btnEliminar" onAction="#onEliminar" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="🗑 Eliminar" />
                              <Button fx:id="btnEditar" onAction="#onEditar" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;" text="💾 Guardar Cambios" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #27ae60; -fx-border-width: 1;" HBox.hgrow="ALWAYS">
                     <children>
                        <Label text="Agregar Nuevo Registro" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                        <Separator />
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Valor a agregar:" style="-fx-font-size: 11px;" />
                              <TextField fx:id="txtValorAgregar" prefHeight="30.0" promptText="Escriba el nombre del nuevo elemento..." />
                           </children>
                        </VBox>
                        <Region VBox.vgrow="ALWAYS" />
                        <HBox alignment="CENTER_RIGHT">
                           <children>
                              <Button fx:id="btnAgregar" onAction="#onAgregar" prefWidth="120.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="➕ Agregar" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>

         </children>
      </VBox>
   </children>
</AnchorPane>
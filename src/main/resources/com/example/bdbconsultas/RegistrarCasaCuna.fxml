<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="580.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.CasaCunaController">
    <children>
        <VBox alignment="TOP_CENTER" layoutX="50.0" layoutY="20.0" spacing="15.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0">
            <children>
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Registrar Casa Cuna">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Text>

                <Separator prefWidth="200.0" />

                <TableView fx:id="tblDatos" layoutX="233.0" layoutY="52.0" prefHeight="350.0" prefWidth="506.0">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="96.66667175292969" text="ID" />
                        <TableColumn fx:id="colNombreCompleto" prefWidth="407.33331298828125" text="Nombre completo" />
                    </columns>
                </TableView>

                <GridPane hgap="15.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="245.0" minWidth="10.0" prefWidth="180.0" />
                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="334.0" minWidth="10.0" prefWidth="305.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="80.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="80.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="80.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Label text="ID Persona Responsable:" />
                        <TextField fx:id="txtIdPerson" promptText="Ej: 10" GridPane.columnIndex="1" />

                        <Label text="¿Requiere donaciones?" GridPane.rowIndex="1" />
                        <CheckBox fx:id="checkRequiresFood" mnemonicParsing="false" text="Sí, necesita apoyo con alimento" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <Label text="Tipos de mascota aceptados:" GridPane.rowIndex="2" />
                        <ListView fx:id="listPetTypes" prefHeight="70.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Tamaños aceptados:" GridPane.rowIndex="3" />
                        <ListView fx:id="listPetSizes" prefHeight="70.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <Label text="Niveles de energía aceptados:" GridPane.rowIndex="4" />
                        <ListView fx:id="listEnergyLevels" prefHeight="70.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                        <Label text="Distrito:" GridPane.rowIndex="5" />
                        <ComboBox fx:id="comboDistrict" prefWidth="305.0" promptText="Seleccione ubicación" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                    </children>
                </GridPane>

                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#guardarCasaCuna" prefHeight="35.0" prefWidth="130.0" text="Guardar Registro" />
                        <Button mnemonicParsing="false" onAction="#cancelar" prefHeight="35.0" prefWidth="130.0" text="Volver" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
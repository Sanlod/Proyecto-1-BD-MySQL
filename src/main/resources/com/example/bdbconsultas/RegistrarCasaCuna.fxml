<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="700.0" prefWidth="800.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.CasaCunaController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>

                <HBox alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #16a085, #1abc9c); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
                    <children>
                        <VBox>
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Registro de Casa Cuna" />
                                <Label style="-fx-text-fill: #e8f8f5; -fx-font-size: 12px;" text="Asignación de hogares temporales para rescates" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                    <children>

                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="1. Seleccione la Persona Responsable" />
                                <TableView fx:id="tblDatos" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colId" maxWidth="60.0" minWidth="40.0" prefWidth="50.0" text="ID" />
                                        <TableColumn fx:id="colNombreCompleto" prefWidth="200.0" text="Nombre Completo" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f8f9f9; -fx-padding: 8;">
                                    <children>
                                        <Label text="ID Seleccionado:" />
                                        <TextField fx:id="txtIdPerson" prefWidth="80.0" promptText="ID" style="-fx-background-color: #e8f8f5; -fx-font-weight: bold;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="2. Detalles de Capacidad y Ubicación" />

                                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: white;">
                                    <content>
                                        <GridPane hgap="10.0" vgap="12.0">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="140.0" />
                                            </columnConstraints>
                                            <children>
                                                <VBox spacing="5" GridPane.rowIndex="0">
                                                    <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Donaciones" />
                                                    <CheckBox fx:id="checkRequiresFood" mnemonicParsing="false" text="Requiere apoyo con alimento" />
                                                </VBox>

                                                <VBox spacing="5" GridPane.rowIndex="1">
                                                    <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Especies Aceptadas" />
                                                    <ListView fx:id="listPetTypes" prefHeight="80.0" style="-fx-background-radius: 5;" />
                                                </VBox>

                                                <VBox spacing="5" GridPane.rowIndex="2">
                                                    <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Tamaños Admitidos" />
                                                    <ListView fx:id="listPetSizes" prefHeight="80.0" style="-fx-background-radius: 5;" />
                                                </VBox>

                                                <VBox spacing="5" GridPane.rowIndex="3">
                                                    <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Niveles de Energía" />
                                                    <ListView fx:id="listEnergyLevels" prefHeight="80.0" style="-fx-background-radius: 5;" />
                                                </VBox>

                                                <VBox spacing="5" GridPane.rowIndex="4">
                                                    <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Ubicación (Distrito)" />
                                                    <ComboBox fx:id="comboDistrict" maxWidth="Infinity" promptText="Seleccionar ubicación" />
                                                </VBox>
                                            </children>
                                            <rowConstraints>
                                                <RowConstraints />
                                                <RowConstraints />
                                                <RowConstraints />
                                                <RowConstraints />
                                                <RowConstraints />
                                            </rowConstraints>
                                        </GridPane>
                                    </content>
                                </ScrollPane>

                                <Region VBox.vgrow="ALWAYS" />

                                <HBox spacing="10.0">
                                    <children>
                                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#guardarCasaCuna" prefHeight="40.0" style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="GUARDAR" HBox.hgrow="ALWAYS" />
                                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#cancelar" prefHeight="40.0" style="-fx-background-color: #ecf0f1; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-cursor: hand;" text="VOLVER" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
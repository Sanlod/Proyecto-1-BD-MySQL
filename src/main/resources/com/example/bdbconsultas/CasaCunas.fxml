<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.bdbconsultas.CasaCunaUserController"
            prefHeight="500.0" prefWidth="800.0">

    <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">

        <Label text="Casas Cuna">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <ComboBox fx:id="cmbFiltroTipo" promptText="Tipo Mascota" prefWidth="150.0" />
            <ComboBox fx:id="cmbFiltroTamano" promptText="Tamaño" prefWidth="130.0" />
            <ComboBox fx:id="cmbFiltroEnergia" promptText="Energía" prefWidth="130.0" />
            <ComboBox fx:id="cmbFiltroDistrito" promptText="Distrito" prefWidth="150.0" />
            <Button text="Limpiar Filtros" onAction="#limpiarFiltros" />
        </HBox>

        <TableView fx:id="tblCasaCuna" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNumero" prefWidth="30.0" text="#" />
                <TableColumn fx:id="colNombreDueño" prefWidth="160.0" text="Nombre del Dueño" />
                <TableColumn fx:id="colDistrito" prefWidth="90.0" text="Distrito" />
                <TableColumn fx:id="colTipoMascota" prefWidth="150.0" text="Tipo Mascota" />
                <TableColumn fx:id="colTamanoMascota" prefWidth="150.0" text="Tamaño" />
                <TableColumn fx:id="colNivelEnergia" prefWidth="200.0" text="Nivel Energía" />
                <TableColumn fx:id="colDonaciones" prefWidth="100.0" text="Donaciones" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button fx:id="btnVolver" onAction="#switchVolver" text="Volver al Menú" />
        </HBox>
    </VBox>
</AnchorPane>
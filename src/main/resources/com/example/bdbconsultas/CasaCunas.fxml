<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="1000.0" style="-fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bdbconsultas.CasaCunaUserController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>

                <HBox alignment="CENTER_LEFT" prefHeight="70.0" style="-fx-background-color: linear-gradient(to right, #2980b9, #3498db); -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 4);">
                    <children>
                        <VBox>
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="Directorio de Casas Cuna" />
                                <Label style="-fx-text-fill: #ebf5fb; -fx-font-size: 12px;" text="Consulta de hogares temporales disponibles" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnVolver" onAction="#switchVolver" prefHeight="35.0" prefWidth="130.0" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="↩ Volver al Menú" />
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <children>
                        <VBox spacing="5">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Tipo de Mascota" />
                            <ComboBox fx:id="cmbFiltroTipo" prefWidth="150.0" promptText="Seleccionar..." />
                        </VBox>
                        <VBox spacing="5">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Tamaño" />
                            <ComboBox fx:id="cmbFiltroTamano" prefWidth="130.0" promptText="Cualquiera" />
                        </VBox>
                        <VBox spacing="5">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Nivel de Energía" />
                            <ComboBox fx:id="cmbFiltroEnergia" prefWidth="130.0" promptText="Cualquiera" />
                        </VBox>
                        <VBox spacing="5">
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" text="Ubicación (Distrito)" />
                            <ComboBox fx:id="cmbFiltroDistrito" prefWidth="150.0" promptText="Todos" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#limpiarFiltros" prefHeight="35.0" style="-fx-background-color: #ecf0f1; -fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-cursor: hand;" text="🧹 Limpiar Filtros" />
                    </children>
                </HBox>

                <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" VBox.vgrow="ALWAYS">
                    <children>
                        <TableView fx:id="tblCasaCuna" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colNumero" maxWidth="40.0" minWidth="30.0" prefWidth="35.0" text="#" />
                                <TableColumn fx:id="colNombreDueño" prefWidth="160.0" text="Responsable" />
                                <TableColumn fx:id="colDistrito" prefWidth="110.0" text="Distrito" />
                                <TableColumn fx:id="colTipoMascota" prefWidth="120.0" text="Especie Aceptada" />
                                <TableColumn fx:id="colTamanoMascota" prefWidth="100.0" text="Capacidad" />
                                <TableColumn fx:id="colNivelEnergia" prefWidth="120.0" text="Energía Permitida" />
                                <TableColumn fx:id="colDonaciones" prefWidth="110.0" text="Donaciones" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>